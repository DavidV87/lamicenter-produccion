// =============================================================
// Lamicenter — Schema Prisma
// Base de datos: PostgreSQL 18
//
// Convenciones:
//   - Nombres de tablas y campos en español (snake_case en BD)
//   - camelCase en modelos y campos Prisma
//   - UUIDs como identificadores principales (gen_random_uuid)
//   - Sin eliminación física en entidades críticas (activo boolean)
//   - Estados controlados por tablas de máquina de estados
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// BLOQUE 1 — Usuarios, Roles, Permisos, Auditoría, Máquina de Estados
// =============================================================

// ------------------------------------------------------------
// Enum: tipo de acción registrada en auditoría general
// ------------------------------------------------------------
enum TipoAccionAuditoria {
  CREAR
  ACTUALIZAR
  CAMBIO_ESTADO
  AUTORIZACION
  CANCELACION
  REPROCESO
  DESPACHO
  PQRS
  OTRO
}

// ------------------------------------------------------------
// Sedes — instalaciones físicas o sucursales de la empresa
// ------------------------------------------------------------
model Sede {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique @db.VarChar(100)
  direccion     String?  @db.VarChar(255)
  telefono      String?  @db.VarChar(30)
  codigo        String?  @unique @db.VarChar(20)
  correo        String?  @db.VarChar(150)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuarios               Usuario[]
  maquinas               Maquina[]
  ubicaciones            Ubicacion[]
  clientesPrincipales    Cliente[]
  documentos             Documento[]  @relation("DocumentoSede")
  facturas               Factura[]    @relation("FacturaSede")
  pedidosComoVenta       Pedido[]     @relation("PedidoSedeVenta")
  pedidosComoResponsable Pedido[]     @relation("PedidoSedeResponsable")
  pedidosComoDespacho    Pedido[]     @relation("PedidoSedeDespacho")
  pedidoSedesOrigen      PedidoSede[] @relation("PedidoSedeOrigen")
  pedidoSedesDestino     PedidoSede[] @relation("PedidoSedeDestino")

  @@map("sedes")
}

// ------------------------------------------------------------
// Roles — perfiles de acceso y autorización
// ------------------------------------------------------------
model Rol {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique @db.VarChar(80)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuarios                Usuario[]
  rolesPermisos           RolPermiso[]
  transicionesAutorizadas TransicionRolAutorizado[]

  @@map("roles")
}

// ------------------------------------------------------------
// Usuarios — operadores del sistema
// ------------------------------------------------------------
model Usuario {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String    @db.VarChar(150)
  email         String    @unique @db.VarChar(200)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  sedeId        String    @map("sede_id") @db.Uuid
  rolId         String    @map("rol_id") @db.Uuid
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  ultimoAcceso  DateTime? @map("ultimo_acceso")

  sede                        Sede                    @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  rol                         Rol                     @relation(fields: [rolId], references: [id], onDelete: Restrict)
  auditorias                  AuditoriaGeneral[]
  documentosCreados           Documento[]             @relation("DocumentoCreadoPor")
  versionesSubidas            DocumentoVersion[]      @relation("VersionSubidaPor")
  facturasComoVendedor        Factura[]               @relation("FacturaVendedor")
  facturasCreadas             Factura[]               @relation("FacturaCreadaPor")
  itemsMapeados               FacturaItem[]           @relation("ItemMapeadoPor")
  documentosRelacionados      DocumentoRelacionado[]  @relation("DocumentoRelacionadoPor")
  lecturasDocumento           LecturaDocumento[]      @relation("LecturaProcesadaPor")
  pedidosComoVendedor         Pedido[]                @relation("PedidoVendedor")
  pedidosCreados              Pedido[]                @relation("PedidoCreadoPor")
  validacionesPedido          ValidacionPedido[]
  asignacionesComoVendedor    AsignacionPedido[]      @relation("AsignacionVendedor")
  asignacionesRealizadas      AsignacionPedido[]      @relation("AsignacionRealizadaPor")
  materialesClienteRecibidos  MaterialCliente[]       @relation("MaterialClienteRecibidoPor")
  materialesClienteCreados    MaterialCliente[]       @relation("MaterialClienteCreadoPor")
  bloqueosPedidoCreados       BloqueoPedido[]         @relation("BloqueoPedidoCreadoPor")
  bloqueosPedidoDesbloqueados BloqueoPedido[]         @relation("BloqueoPedidoDesbloqueadoPor")
  pedidoSedesSolicitadas      PedidoSede[]            @relation("PedidoSedeSolicitadaPor")
  pedidoSedesAutorizadas      PedidoSede[]            @relation("PedidoSedeAutorizadaPor")
  historialEstadosPedido      HistorialEstadoPedido[]
  entregasRealizadas          Entrega[]
  facturasPedidoRelacionadas  FacturaPedido[]
  pedidoItemDocumentosCreados PedidoItemDocumento[]

  @@index([sedeId])
  @@index([rolId])
  @@index([activo])
  @@map("usuarios")
}

// ------------------------------------------------------------
// Permisos — acciones granulares habilitadas por módulo
// Código usa notación "modulo.accion" (ej: pedidos.crear)
// ------------------------------------------------------------
model Permiso {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo        String   @unique @db.VarChar(100)
  descripcion   String?  @db.Text
  modulo        String   @db.VarChar(80)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  rolesPermisos RolPermiso[]

  @@index([modulo])
  @@map("permisos")
}

// ------------------------------------------------------------
// RolPermiso — asignación de permisos a roles (M:M)
// ------------------------------------------------------------
model RolPermiso {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolId     String   @map("rol_id") @db.Uuid
  permisoId String   @map("permiso_id") @db.Uuid
  creadoEn  DateTime @default(now()) @map("creado_en")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@map("roles_permisos")
}

// ------------------------------------------------------------
// AuditoriaGeneral — registro inmutable de operaciones críticas
// registroId referencia el UUID del registro afectado en cualquier tabla.
// usuarioId puede ser null cuando la acción es generada por el sistema.
// datosAnteriores / datosNuevos almacenan el snapshot del registro.
// metadata almacena contexto adicional libre según el tipo de acción.
// ------------------------------------------------------------
model AuditoriaGeneral {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tablaAfectada   String              @map("tabla_afectada") @db.VarChar(100)
  registroId      String              @map("registro_id") @db.Uuid
  accion          TipoAccionAuditoria
  datosAnteriores Json?               @map("datos_anteriores") @db.JsonB
  datosNuevos     Json?               @map("datos_nuevos") @db.JsonB
  metadata        Json?               @db.JsonB
  usuarioId       String?             @map("usuario_id") @db.Uuid
  ipOrigen        String?             @map("ip_origen") @db.VarChar(45)
  creadoEn        DateTime            @default(now()) @map("creado_en")
  userAgent       String?             @map("user_agent") @db.VarChar(500)

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([tablaAfectada, registroId])
  @@index([usuarioId])
  @@index([accion])
  @@index([creadoEn])
  @@map("auditoria_general")
}

// ------------------------------------------------------------
// EstadoSistema — catálogo de estados por módulo de negocio
// La combinación (modulo, codigo) es única.
// Ejemplos de módulo: pedido, orden_produccion, despacho, pqrs
// ------------------------------------------------------------
model EstadoSistema {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modulo          String   @db.VarChar(80)
  codigo          String   @db.VarChar(80)
  nombre          String   @db.VarChar(100)
  descripcion     String?  @db.Text
  esEstadoInicial Boolean  @default(false) @map("es_estado_inicial")
  esEstadoFinal   Boolean  @default(false) @map("es_estado_final")
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now()) @map("creado_en")
  actualizadoEn   DateTime @updatedAt @map("actualizado_en")

  transicionesComoOrigen   TransicionEstado[]      @relation("EstadoOrigen")
  transicionesComoDestino  TransicionEstado[]      @relation("EstadoDestino")
  pedidos                  Pedido[]                @relation("PedidoEstado")
  historialAnteriorPedidos HistorialEstadoPedido[] @relation("EstadoAnteriorPedido")
  historialNuevoPedidos    HistorialEstadoPedido[] @relation("EstadoNuevoPedido")

  @@unique([modulo, codigo])
  @@index([modulo])
  @@map("estados_sistema")
}

// ------------------------------------------------------------
// TransicionEstado — arcos válidos de la máquina de estados
// requiereAutorizacion indica si el rol debe estar en transiciones_roles_autorizados
// ------------------------------------------------------------
model TransicionEstado {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estadoOrigenId       String   @map("estado_origen_id") @db.Uuid
  estadoDestinoId      String   @map("estado_destino_id") @db.Uuid
  nombre               String?  @db.VarChar(150)
  requiereAutorizacion Boolean  @default(false) @map("requiere_autorizacion")
  activo               Boolean  @default(true)
  creadoEn             DateTime @default(now()) @map("creado_en")
  actualizadoEn        DateTime @updatedAt @map("actualizado_en")

  estadoOrigen     EstadoSistema             @relation("EstadoOrigen", fields: [estadoOrigenId], references: [id], onDelete: Restrict)
  estadoDestino    EstadoSistema             @relation("EstadoDestino", fields: [estadoDestinoId], references: [id], onDelete: Restrict)
  rolesAutorizados TransicionRolAutorizado[]

  @@unique([estadoOrigenId, estadoDestinoId])
  @@index([estadoOrigenId])
  @@index([estadoDestinoId])
  @@map("transiciones_estado")
}

// ------------------------------------------------------------
// TransicionRolAutorizado — roles que pueden ejecutar una transición (M:M)
// ------------------------------------------------------------
model TransicionRolAutorizado {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transicionId String   @map("transicion_id") @db.Uuid
  rolId        String   @map("rol_id") @db.Uuid
  creadoEn     DateTime @default(now()) @map("creado_en")

  transicion TransicionEstado @relation(fields: [transicionId], references: [id], onDelete: Cascade)
  rol        Rol              @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([transicionId, rolId])
  @@map("transiciones_roles_autorizados")
}

// =============================================================
// BLOQUE 2 — Catálogos: Items, Clientes, Proveedores, Máquinas, Ubicaciones, Novedades, Documentos
// =============================================================

// ------------------------------------------------------------
// Enum: comportamiento del tipo de ítem
// Determina cómo el sistema trata los ítems de ese tipo.
// Evita el uso de esServicio boolean redundante en el modelo Item.
// ------------------------------------------------------------
enum ComportamientoTipoItem {
  PRODUCTO
  SERVICIO
  MATERIA_PRIMA
  INSUMO
}

// ------------------------------------------------------------
// Enum: unidad de medida estándar del ítem
// Aplica según la naturaleza física del material o servicio.
// M2: tableros y paneles. ML: enchape y tapacanto. UN: piezas y herrajes.
// ------------------------------------------------------------
enum UnidadMedida {
  METRO_CUADRADO
  METRO_LINEAL
  UNIDAD
  HOJA
  KILOGRAMO
  LITRO
  METRO_CUBICO
}

// ------------------------------------------------------------
// Enum: tipo de identificación fiscal o legal
// Aplica a clientes y proveedores, personas naturales o jurídicas.
// ------------------------------------------------------------
enum TipoIdentificacion {
  NIT
  CC
  CE
  PAS
  OTRO
}

// ------------------------------------------------------------
// Enum: categoría principal de un proveedor según lo que suministra
// ------------------------------------------------------------
enum TipoProveedor {
  MATERIAL
  SERVICIO
  TRANSPORTE
  MIXTO
}

// ------------------------------------------------------------
// Enum: entidad del negocio sobre la que aplica un tipo de novedad
// Controla el campo aplica_a en tipos_novedad sin texto libre.
// ------------------------------------------------------------
enum AplicaNovedadA {
  PEDIDO
  ORDEN_PRODUCCION
  SUBORDEN
  DESPACHO
  COMPRA
  MATERIAL
  GENERAL
}

// ------------------------------------------------------------
// TipoItem — catálogo de tipos de ítem que controlan el comportamiento
// El campo comportamiento determina el tratamiento del ítem en el sistema.
// No se usa esServicio en Item: se determina leyendo TipoItem.comportamiento.
// ------------------------------------------------------------
model TipoItem {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String                 @unique @db.VarChar(100)
  descripcion    String?                @db.Text
  comportamiento ComportamientoTipoItem
  activo         Boolean                @default(true)
  creadoEn       DateTime               @default(now()) @map("creado_en")
  actualizadoEn  DateTime               @updatedAt @map("actualizado_en")

  items Item[]

  @@map("tipos_item")
}

// ------------------------------------------------------------
// Item — catálogo maestro de ítems (productos, servicios, materias primas)
// precioVentaReferencia y costoReferencia son referenciales, no de facturación.
// controlaInventario: activa movimientos de stock para este ítem.
// requiereCorte: indica que el ítem es procesado por maquinaria CNC.
// metadata: atributos flexibles adicionales (color, textura, dimensiones, marca).
// ------------------------------------------------------------
model Item {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoItemId            String       @map("tipo_item_id") @db.Uuid
  codigo                String       @unique @db.VarChar(80)
  nombre                String       @db.VarChar(200)
  descripcion           String?      @db.Text
  unidadMedida          UnidadMedida @map("unidad_medida")
  precioVentaReferencia Decimal?     @map("precio_venta_referencia") @db.Decimal(14, 4)
  costoReferencia       Decimal?     @map("costo_referencia") @db.Decimal(14, 4)
  controlaInventario    Boolean      @default(false) @map("controla_inventario")
  requiereCorte         Boolean      @default(false) @map("requiere_corte")
  permiteFraccion       Boolean      @default(false) @map("permite_fraccion")
  metadata              Json?        @db.JsonB
  activo                Boolean      @default(true)
  creadoEn              DateTime     @default(now()) @map("creado_en")
  actualizadoEn         DateTime     @updatedAt @map("actualizado_en")

  tipoItem     TipoItem      @relation(fields: [tipoItemId], references: [id], onDelete: Restrict)
  facturaItems FacturaItem[]
  pedidoItems  PedidoItem[]

  @@index([codigo])
  @@index([tipoItemId])
  @@index([activo])
  @@map("items")
}

// ------------------------------------------------------------
// Cliente — personas naturales o empresas que realizan pedidos
// La identificacion es única para prevenir duplicados en el sistema.
// Un cliente puede tener múltiples contactos a través de contactos_cliente.
// ------------------------------------------------------------
model Cliente {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  razonSocial        String             @map("razon_social") @db.VarChar(200)
  nombreComercial    String?            @map("nombre_comercial") @db.VarChar(200)
  identificacion     String             @unique @db.VarChar(30)
  tipoIdentificacion TipoIdentificacion @map("tipo_identificacion")
  sedePrincipalId    String?            @map("sede_principal_id") @db.Uuid
  telefono           String?            @db.VarChar(30)
  correo             String?            @db.VarChar(150)
  direccion          String?            @db.VarChar(255)
  ciudad             String?            @db.VarChar(100)
  activo             Boolean            @default(true)
  creadoEn           DateTime           @default(now()) @map("creado_en")
  actualizadoEn      DateTime           @updatedAt @map("actualizado_en")

  sedePrincipal Sede?             @relation(fields: [sedePrincipalId], references: [id], onDelete: SetNull)
  contactos     ContactoCliente[]
  facturas      Factura[]         @relation("FacturaCliente")
  pedidos       Pedido[]

  @@index([sedePrincipalId])
  @@index([activo])
  @@map("clientes")
}

// ------------------------------------------------------------
// ContactoCliente — personas de contacto vinculadas a un cliente
// esPrincipal identifica el contacto preferido para comunicaciones.
// La eliminación del cliente propaga en cascada a sus contactos.
// ------------------------------------------------------------
model ContactoCliente {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId     String   @map("cliente_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  cargo         String?  @db.VarChar(100)
  telefono      String?  @db.VarChar(30)
  correo        String?  @db.VarChar(150)
  esPrincipal   Boolean  @default(false) @map("es_principal")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  entregas Entrega[]

  @@index([clienteId])
  @@map("contactos_cliente")
}

// ------------------------------------------------------------
// Proveedor — empresas o personas que suministran materiales o servicios
// La identificacion es única para prevenir duplicados en el sistema.
// ------------------------------------------------------------
model Proveedor {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  razonSocial        String             @map("razon_social") @db.VarChar(200)
  nombreComercial    String?            @map("nombre_comercial") @db.VarChar(200)
  identificacion     String             @unique @db.VarChar(30)
  tipoIdentificacion TipoIdentificacion @map("tipo_identificacion")
  tipoProveedor      TipoProveedor      @map("tipo_proveedor")
  telefono           String?            @db.VarChar(30)
  correo             String?            @db.VarChar(150)
  direccion          String?            @db.VarChar(255)
  ciudad             String?            @db.VarChar(100)
  activo             Boolean            @default(true)
  creadoEn           DateTime           @default(now()) @map("creado_en")
  actualizadoEn      DateTime           @updatedAt @map("actualizado_en")

  @@index([activo])
  @@index([tipoProveedor])
  @@map("proveedores")
}

// ------------------------------------------------------------
// Maquina — equipos productivos registrados por sede
// sedeId es obligatorio: toda máquina debe pertenecer a una sede física.
// ------------------------------------------------------------
model Maquina {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId        String   @map("sede_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  codigo        String   @unique @db.VarChar(50)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  sede Sede @relation(fields: [sedeId], references: [id], onDelete: Restrict)

  @@index([sedeId])
  @@index([activo])
  @@map("maquinas")
}

// ------------------------------------------------------------
// Ubicacion — espacios físicos de almacenamiento o proceso por sede
// Permite trazar la posición de materiales y productos en proceso.
// sedeId es obligatorio: toda ubicación pertenece a una sede física.
// ------------------------------------------------------------
model Ubicacion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId        String   @map("sede_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  codigo        String   @unique @db.VarChar(50)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  sede Sede @relation(fields: [sedeId], references: [id], onDelete: Restrict)

  @@index([sedeId])
  @@index([activo])
  @@map("ubicaciones")
}

// ------------------------------------------------------------
// TipoNovedad — catálogo de tipos de novedad operativa
// aplicaA define la entidad del sistema afectada, controlado por enum.
// No se usa texto libre para garantizar integridad del catálogo.
// ------------------------------------------------------------
model TipoNovedad {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String         @unique @db.VarChar(100)
  descripcion   String?        @db.Text
  aplicaA       AplicaNovedadA @map("aplica_a")
  activo        Boolean        @default(true)
  creadoEn      DateTime       @default(now()) @map("creado_en")
  actualizadoEn DateTime       @updatedAt @map("actualizado_en")

  @@index([aplicaA])
  @@map("tipos_novedad")
}

// ------------------------------------------------------------
// TipoDocumento — catálogo de tipos de documento del sistema
// Ejemplos de uso: FACTURA, REMISION, ORDEN_COMPRA, COTIZACION, PLANO_CORTE
// codigo es el identificador corto para referencias internas y reportes.
// ------------------------------------------------------------
model TipoDocumento {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre                 String   @unique @db.VarChar(100)
  codigo                 String   @unique @db.VarChar(30)
  descripcion            String?  @db.Text
  requiereVersionamiento Boolean  @default(false) @map("requiere_versionamiento")
  activo                 Boolean  @default(true)
  creadoEn               DateTime @default(now()) @map("creado_en")
  actualizadoEn          DateTime @updatedAt @map("actualizado_en")

  documentos Documento[]

  @@map("tipos_documento")
}

// =============================================================
// BLOQUE 3 — Documentos, Facturas y Versionamiento
// =============================================================

// ------------------------------------------------------------
// Enum: estado de mapeo de un ítem de factura hacia el catálogo interno
// PENDIENTE: aún no procesado.
// MAPEADO_AUTOMATICO: el parser identificó y asoció el ítem automáticamente.
// MAPEADO_MANUAL: un usuario asoció el ítem manualmente desde la interfaz.
// REQUIERE_REVISION: el parser dudó; necesita confirmación humana antes de continuar.
// IGNORADO: el ítem no aplica para producción (descuento, flete, impuesto extra).
// ------------------------------------------------------------
enum EstadoMapeo {
  PENDIENTE
  MAPEADO_AUTOMATICO
  MAPEADO_MANUAL
  REQUIERE_REVISION
  IGNORADO
}

// ------------------------------------------------------------
// Enum: modalidad de pago registrada en la factura comercial
// ------------------------------------------------------------
enum TipoPago {
  CONTADO
  CREDITO
  CHEQUE
  TRANSFERENCIA
  MIXTO
}

// ------------------------------------------------------------
// Enum: estado de cobro de la factura
// VENCIDO: crédito superó la fecha de vencimiento sin pago total.
// ------------------------------------------------------------
enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  VENCIDO
  ANULADO
}

// ------------------------------------------------------------
// Enum: estado operativo de la factura dentro del sistema
// BLOQUEADA: factura anulada en ContaPyme; requiere revisión del administrador de punto.
// REEMPLAZADA: sustituida por otra factura dentro del mismo pedido.
// ------------------------------------------------------------
enum EstadoFactura {
  ACTIVA
  PENDIENTE_REVISION
  BLOQUEADA
  ANULADA
  REEMPLAZADA
}

// ------------------------------------------------------------
// Enum: tipo de relación semántica entre dos documentos
// Permite trazar vínculos: factura↔plano, factura↔nota crédito, reemplazo, etc.
// ------------------------------------------------------------
enum TipoRelacionDocumento {
  FACTURA_PLANO
  NOTA_CREDITO
  VERSION
  COMPLEMENTO
  REEMPLAZO
  ANULACION
  REFERENCIA
}

// ------------------------------------------------------------
// Enum: estado del ciclo de vida del proceso de lectura/parsing de una versión
// REVISION_MANUAL: el parser no pudo completar la lectura; requiere intervención humana.
// ------------------------------------------------------------
enum EstadoLecturaDocumento {
  PENDIENTE
  EN_PROCESO
  EXITOSA
  FALLIDA
  REVISION_MANUAL
}

// ------------------------------------------------------------
// Enum: servicio o método que procesó la lectura del documento
// OCR_CONTPYME: lectura automática de facturas exportadas desde ContaPyme.
// PARSER_CUTLIST: parsing automático de planos CutList.
// IMPORTADOR_MANUAL: carga realizada directamente por un usuario desde la interfaz.
// ------------------------------------------------------------
enum ServicioLectura {
  OCR_CONTPYME
  PARSER_CUTLIST
  IMPORTADOR_MANUAL
}

// ------------------------------------------------------------
// Documento — contenedor lógico que agrupa versiones de un archivo
// Puede representar: factura, plano CutList, nota crédito, remisión, cotización, etc.
// No almacena archivos físicos: los archivos van en documentos_versiones (inmutables).
// tipoDocumentoId clasifica el documento según el catálogo tipos_documento del bloque 2.
// activo: soft delete; los documentos críticos no se eliminan físicamente.
// metadata: campos adicionales flexibles según el tipo de documento.
// ------------------------------------------------------------
model Documento {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoDocumentoId    String   @map("tipo_documento_id") @db.Uuid
  titulo             String   @db.VarChar(200)
  descripcion        String?  @db.Text
  sedeId             String?  @map("sede_id") @db.Uuid
  creadoPorUsuarioId String   @map("creado_por_usuario_id") @db.Uuid
  activo             Boolean  @default(true)
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  tipoDocumento        TipoDocumento          @relation(fields: [tipoDocumentoId], references: [id], onDelete: Restrict)
  sede                 Sede?                  @relation("DocumentoSede", fields: [sedeId], references: [id], onDelete: SetNull)
  creadoPor            Usuario                @relation("DocumentoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  versiones            DocumentoVersion[]
  factura              Factura?
  relacionesOrigen     DocumentoRelacionado[] @relation("DocumentoOrigen")
  relacionesDestino    DocumentoRelacionado[] @relation("DocumentoDestino")
  pedidoItemDocumentos PedidoItemDocumento[]

  @@index([tipoDocumentoId])
  @@index([sedeId])
  @@index([creadoPorUsuarioId])
  @@index([activo])
  @@map("documentos")
}

// ------------------------------------------------------------
// DocumentoVersion — versión inmutable de un archivo físico asociado a un documento
// Cada carga genera una nueva versión; nunca se reemplaza ni elimina la versión anterior.
// version: entero incremental por documento (1, 2, 3...); único por documento.
// hashArchivo: sha256/md5 opcional para verificar integridad y detectar duplicados.
// rutaArchivo: ruta de almacenamiento interno; no es URL pública directa.
// pesoBytes: BigInt para soportar archivos de hasta varios GB sin desbordamiento.
// No tiene actualizadoEn: la inmutabilidad garantiza que el registro no cambia.
// ------------------------------------------------------------
model DocumentoVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId        String   @map("documento_id") @db.Uuid
  version            Int
  rutaArchivo        String   @map("ruta_archivo") @db.VarChar(500)
  nombreOriginal     String   @map("nombre_original") @db.VarChar(255)
  extension          String   @db.VarChar(20)
  mimeType           String   @map("mime_type") @db.VarChar(100)
  pesoBytes          BigInt   @map("peso_bytes")
  hashArchivo        String?  @map("hash_archivo") @db.VarChar(128)
  subidoPorUsuarioId String   @map("subido_por_usuario_id") @db.Uuid
  creadoEn           DateTime @default(now()) @map("creado_en")

  documento Documento          @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  subidoPor Usuario            @relation("VersionSubidaPor", fields: [subidoPorUsuarioId], references: [id], onDelete: Restrict)
  lecturas  LecturaDocumento[]

  @@unique([documentoId, version])
  @@index([documentoId])
  @@index([subidoPorUsuarioId])
  @@map("documentos_versiones")
}

// ------------------------------------------------------------
// Factura — factura comercial leída desde ContaPyme o importada como PDF
// documentoId es unique: cada factura corresponde a un único documento lógico.
// vendedorId es nullable: puede no conocerse en facturas históricas importadas.
// creadoPorUsuarioId: auditoría de quién registró la factura en el sistema.
// saldoPendiente: se actualiza cuando se registran abonos (total − suma de abonos).
// estadoFactura BLOQUEADA: anulación en ContaPyme obliga revisión antes de continuar producción.
// metadata: preserva campos adicionales del sistema ContaPyme u otras fuentes externas.
// Si el parser falla, el operador puede completar o corregir todos los campos manualmente.
// ------------------------------------------------------------
model Factura {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId        String        @unique @map("documento_id") @db.Uuid
  sedeId             String        @map("sede_id") @db.Uuid
  clienteId          String        @map("cliente_id") @db.Uuid
  vendedorId         String?       @map("vendedor_id") @db.Uuid
  creadoPorUsuarioId String?       @map("creado_por_usuario_id") @db.Uuid
  numeroFactura      String        @unique @map("numero_factura") @db.VarChar(50)
  fechaFactura       DateTime      @map("fecha_factura") @db.Date
  tipoPago           TipoPago      @map("tipo_pago")
  estadoPago         EstadoPago    @default(PENDIENTE) @map("estado_pago")
  estadoFactura      EstadoFactura @default(ACTIVA) @map("estado_factura")
  subtotal           Decimal       @db.Decimal(16, 4)
  impuestos          Decimal       @db.Decimal(16, 4)
  total              Decimal       @db.Decimal(16, 4)
  saldoPendiente     Decimal       @map("saldo_pendiente") @db.Decimal(16, 4)
  // Origen del saldo pendiente: CONTAPYME (sincronizado), MANUAL (ingresado por usuario), CALCULADO (derivado de abonos registrados)
  fuenteSaldo        String?       @map("fuente_saldo") @db.VarChar(50)
  metadata           Json?         @db.JsonB
  creadoEn           DateTime      @default(now()) @map("creado_en")
  actualizadoEn      DateTime      @updatedAt @map("actualizado_en")

  documento      Documento       @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  sede           Sede            @relation("FacturaSede", fields: [sedeId], references: [id], onDelete: Restrict)
  cliente        Cliente         @relation("FacturaCliente", fields: [clienteId], references: [id], onDelete: Restrict)
  vendedor       Usuario?        @relation("FacturaVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  creadoPor      Usuario?        @relation("FacturaCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)
  items          FacturaItem[]
  facturasPedido FacturaPedido[]

  @@index([sedeId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estadoFactura])
  @@index([estadoPago])
  @@index([fechaFactura])
  @@map("facturas")
}

// ------------------------------------------------------------
// FacturaItem — línea de detalle de una factura
// descripcionOriginal: texto tal como viene del PDF o ContaPyme, sin modificar.
// itemId es nullable: el ítem puede no existir en catálogo aún (estadoMapeo PENDIENTE).
// codigoOriginal / unidadOriginal: valores crudos del documento fuente para trazabilidad.
// estadoMapeo controla el flujo de asociación entre el texto original y el catálogo de ítems.
// mapeadoPorUsuarioId + fechaMapeo: trazabilidad completa del proceso de mapeo.
// IGNORADO: ítems no aplicables a producción (descuentos, fletes, impuestos adicionales).
// El operador puede continuar operación sin bloquear producción aunque haya ítems PENDIENTE.
// ------------------------------------------------------------
model FacturaItem {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facturaId           String      @map("factura_id") @db.Uuid
  itemId              String?     @map("item_id") @db.Uuid
  descripcionOriginal String      @map("descripcion_original") @db.VarChar(500)
  codigoOriginal      String?     @map("codigo_original") @db.VarChar(100)
  unidadOriginal      String?     @map("unidad_original") @db.VarChar(50)
  cantidad            Decimal     @db.Decimal(14, 4)
  precioUnitario      Decimal     @map("precio_unitario") @db.Decimal(14, 4)
  subtotal            Decimal     @db.Decimal(14, 4)
  estadoMapeo         EstadoMapeo @default(PENDIENTE) @map("estado_mapeo")
  mapeadoPorUsuarioId String?     @map("mapeado_por_usuario_id") @db.Uuid
  fechaMapeo          DateTime?   @map("fecha_mapeo")
  observaciones       String?     @db.Text
  creadoEn            DateTime    @default(now()) @map("creado_en")
  actualizadoEn       DateTime    @updatedAt @map("actualizado_en")

  factura     Factura      @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  item        Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  mapeadoPor  Usuario?     @relation("ItemMapeadoPor", fields: [mapeadoPorUsuarioId], references: [id], onDelete: SetNull)
  pedidoItems PedidoItem[]

  @@index([facturaId])
  @@index([itemId])
  @@index([estadoMapeo])
  @@index([mapeadoPorUsuarioId])
  @@map("factura_items")
}

// ------------------------------------------------------------
// DocumentoRelacionado — vínculo explícito entre dos documentos
// Permite trazar relaciones semánticas: factura↔plano, factura↔nota crédito, etc.
// El único en [origen, destino, tipoRelacion] previene relaciones duplicadas del mismo tipo.
// documentoOrigenId ≠ documentoDestinoId: validar en backend que no se relacione consigo mismo.
// ------------------------------------------------------------
model DocumentoRelacionado {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoOrigenId       String                @map("documento_origen_id") @db.Uuid
  documentoDestinoId      String                @map("documento_destino_id") @db.Uuid
  tipoRelacion            TipoRelacionDocumento @map("tipo_relacion")
  relacionadoPorUsuarioId String?               @map("relacionado_por_usuario_id") @db.Uuid
  observaciones           String?               @db.Text
  creadoEn                DateTime              @default(now()) @map("creado_en")

  documentoOrigen  Documento @relation("DocumentoOrigen", fields: [documentoOrigenId], references: [id], onDelete: Restrict)
  documentoDestino Documento @relation("DocumentoDestino", fields: [documentoDestinoId], references: [id], onDelete: Restrict)
  relacionadoPor   Usuario?  @relation("DocumentoRelacionadoPor", fields: [relacionadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@unique([documentoOrigenId, documentoDestinoId, tipoRelacion])
  @@index([documentoOrigenId])
  @@index([documentoDestinoId])
  @@map("documentos_relacionados")
}

// ------------------------------------------------------------
// LecturaDocumento — registro de cada intento de procesamiento automático o manual de una versión
// Separa el procesador humano (procesadoPorUsuarioId) del servicio automático (procesadoPorServicio).
// Solo uno debe estar activo por lectura; validar en backend que no coexistan ambos.
// resultadoLectura: estructura JSON extraída por el parser (campos de factura, ítems de plano, etc.).
// intentos: contador de reintentos automáticos antes de escalar a REVISION_MANUAL.
// errorDetalle: texto del error si el procesamiento falló; facilita diagnóstico y soporte.
// El fallback manual está siempre disponible; la operación no se bloquea por fallo del parser.
// ------------------------------------------------------------
model LecturaDocumento {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoVersionId    String                 @map("documento_version_id") @db.Uuid
  estadoLectura         EstadoLecturaDocumento @default(PENDIENTE) @map("estado_lectura")
  procesadoPorUsuarioId String?                @map("procesado_por_usuario_id") @db.Uuid
  procesadoPorServicio  ServicioLectura?       @map("procesado_por_servicio")
  resultadoLectura      Json?                  @map("resultado_lectura") @db.JsonB
  errorDetalle          String?                @map("error_detalle") @db.Text
  intentos              Int                    @default(0)
  fechaInicio           DateTime?              @map("fecha_inicio")
  fechaFin              DateTime?              @map("fecha_fin")
  metadata              Json?                  @db.JsonB
  creadoEn              DateTime               @default(now()) @map("creado_en")
  actualizadoEn         DateTime               @updatedAt @map("actualizado_en")

  documentoVersion    DocumentoVersion @relation(fields: [documentoVersionId], references: [id], onDelete: Restrict)
  procesadoPorUsuario Usuario?         @relation("LecturaProcesadaPor", fields: [procesadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([documentoVersionId])
  @@index([estadoLectura])
  @@index([procesadoPorUsuarioId])
  @@map("lectura_documentos")
}

// =============================================================
// BLOQUE 4 — Pedidos y Estructura Operativa
// =============================================================

// ------------------------------------------------------------
// Enum: destino operativo de un ítem dentro del pedido
// PRODUCCION: entra al flujo de corte/enchape/perforación en planta.
// DESPACHO_DIRECTO: sale sin pasar por producción (ej: herraje, tablero entero).
// MATERIAL_CLIENTE: material físico que trajo el cliente; no afecta inventario Lamicenter.
// SERVICIO: proceso que no requiere producción en planta (ej: instalación, asesoría).
// ------------------------------------------------------------
enum DestinoOperativo {
  PRODUCCION
  DESPACHO_DIRECTO
  MATERIAL_CLIENTE
  SERVICIO
}

// ------------------------------------------------------------
// Enum: tipo de material físico que el cliente trae a Lamicenter para procesar
// ------------------------------------------------------------
enum TipoMaterialCliente {
  TABLERO
  TAPA
  RETAL
  HERRAJE
  INSUMO
}

// ------------------------------------------------------------
// Enum: estado físico y operativo del material cliente en el sistema
// PENDIENTE_RECEPCION: registrado pero aún no recibido físicamente.
// EN_PROCESO: siendo usado o en espera dentro de producción.
// ------------------------------------------------------------
enum EstadoMaterialCliente {
  PENDIENTE_RECEPCION
  RECIBIDO
  EN_PROCESO
  DEVUELTO
  EXTRAVIADO
}

// ------------------------------------------------------------
// Enum: resultado del proceso de validación de un pedido antes de activarlo para producción
// REQUIERE_AJUSTE: el coordinador detectó inconsistencias que el vendedor debe corregir.
// ------------------------------------------------------------
enum EstadoValidacionPedido {
  PENDIENTE
  APROBADA
  RECHAZADA
  REQUIERE_AJUSTE
}

// ------------------------------------------------------------
// Enum: tipo de movimiento de sede registrado en el historial de traslados del pedido
// ------------------------------------------------------------
enum TipoMovimientoSede {
  TRASLADO_PRODUCCION
  TRASLADO_DESPACHO
  DEVOLUCION_SEDE_ORIGEN
  ASIGNACION_INICIAL
  CAMBIO_RESPONSABLE
}

// ------------------------------------------------------------
// Enum: tipo de relación entre una factura y un pedido
// Corresponde a los tipos definidos en la decisión técnica del Bloque 3/4.
// REEMPLAZO: la nueva factura sustituye operativamente a la anterior anulada.
// DEVOLUCION: nota crédito asociada al pedido por reclamo o ajuste.
// ------------------------------------------------------------
enum TipoRelacionFacturaPedido {
  PRINCIPAL
  ADICIONAL
  REEMPLAZO
  DEVOLUCION
  COMPLEMENTO
}

// ------------------------------------------------------------
// Enum: motivo del bloqueo de un pedido
// FACTURA_ANULADA: ContaPyme anuló la factura asociada; requiere revisión obligatoria.
// REVISION_ADMINISTRATIVA: bloqueo manual por el administrador de punto.
// ------------------------------------------------------------
enum TipoBloqueo {
  FACTURA_ANULADA
  PAGO_VENCIDO
  REVISION_ADMINISTRATIVA
  PENDIENTE_AUTORIZACION
  MANUAL
}

// ------------------------------------------------------------
// Pedido — registro central de una solicitud de trabajo para un cliente
// estadoPedidoId: FK a estados_sistema (no enum libre); permite configuración
// dinámica de estados sin migraciones adicionales.
// sedeVentaId: sede donde el vendedor registró el pedido comercialmente.
// sedeResponsableId: sede operativamente responsable del pedido.
// sedeDespachoId: sede donde se entregará; nullable si aún no está definida.
// fechaListoDespacho: desnormalizado para métricas rápidas de tiempo terminado vs recogido.
// fechaDespachoCompleto: desnormalizado; refleja cuándo el pedido salió completo.
// vendedorId: nullable; puede reasignarse. Historial en asignaciones_pedido.
// ------------------------------------------------------------
model Pedido {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeVentaId           String    @map("sede_venta_id") @db.Uuid
  sedeResponsableId     String    @map("sede_responsable_id") @db.Uuid
  sedeDespachoId        String?   @map("sede_despacho_id") @db.Uuid
  clienteId             String    @map("cliente_id") @db.Uuid
  vendedorId            String?   @map("vendedor_id") @db.Uuid
  creadoPorUsuarioId    String    @map("creado_por_usuario_id") @db.Uuid
  estadoPedidoId        String    @map("estado_pedido_id") @db.Uuid
  observaciones         String?   @db.Text
  fechaListoDespacho    DateTime? @map("fecha_listo_despacho")
  fechaDespachoCompleto DateTime? @map("fecha_despacho_completo")
  metadata              Json?     @db.JsonB
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  sedeVenta         Sede                    @relation("PedidoSedeVenta", fields: [sedeVentaId], references: [id], onDelete: Restrict)
  sedeResponsable   Sede                    @relation("PedidoSedeResponsable", fields: [sedeResponsableId], references: [id], onDelete: Restrict)
  sedeDespacho      Sede?                   @relation("PedidoSedeDespacho", fields: [sedeDespachoId], references: [id], onDelete: SetNull)
  cliente           Cliente                 @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  vendedor          Usuario?                @relation("PedidoVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  creadoPor         Usuario                 @relation("PedidoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  estadoPedido      EstadoSistema           @relation("PedidoEstado", fields: [estadoPedidoId], references: [id], onDelete: Restrict)
  items             PedidoItem[]
  materialesCliente MaterialCliente[]
  validaciones      ValidacionPedido[]
  entregas          Entrega[]
  historialEstados  HistorialEstadoPedido[]
  asignaciones      AsignacionPedido[]
  bloqueos          BloqueoPedido[]
  sedes             PedidoSede[]
  facturasPedido    FacturaPedido[]

  @@index([sedeVentaId])
  @@index([sedeResponsableId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estadoPedidoId])
  @@map("pedidos")
}

// ------------------------------------------------------------
// PedidoItem — línea de ítem dentro de un pedido
// cantidadPendiente: CAMPO CALCULADO INMUTABLE — captura la cantidad pendiente en el momento
// del evento que genera el registro. No se recalcula retroactivamente; es un snapshot inmutable.
// cantidadParaProduccion: porción del ítem que entra al flujo de producción en planta.
// cantidadParaDespachoEntero: porción que se despacha sin procesamiento adicional.
// facturaItemId: trazabilidad del ítem de factura origen que dio lugar a esta línea del pedido.
// esMaterialCliente: indica que el ítem corresponde a material traído por el cliente.
// ------------------------------------------------------------
model PedidoItem {
  id                         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                   String           @map("pedido_id") @db.Uuid
  itemId                     String?          @map("item_id") @db.Uuid
  facturaItemId              String?          @map("factura_item_id") @db.Uuid
  descripcion                String           @db.VarChar(500)
  cantidad                   Decimal          @db.Decimal(14, 4)
  cantidadTotal              Decimal          @map("cantidad_total") @db.Decimal(14, 4)
  cantidadParaProduccion     Decimal          @map("cantidad_para_produccion") @db.Decimal(14, 4)
  cantidadParaDespachoEntero Decimal          @map("cantidad_para_despacho_entero") @db.Decimal(14, 4)
  // CAMPO CALCULADO INMUTABLE: snapshot de cantidad pendiente al momento del evento que lo genera
  cantidadPendiente          Decimal          @map("cantidad_pendiente") @db.Decimal(14, 4)
  precioUnitario             Decimal?         @map("precio_unitario") @db.Decimal(14, 4)
  destinoOperativo           DestinoOperativo @map("destino_operativo")
  esMaterialCliente          Boolean          @default(false) @map("es_material_cliente")
  observaciones              String?          @db.Text
  metadata                   Json?            @db.JsonB
  creadoEn                   DateTime         @default(now()) @map("creado_en")
  actualizadoEn              DateTime         @updatedAt @map("actualizado_en")

  pedido            Pedido                @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  item              Item?                 @relation(fields: [itemId], references: [id], onDelete: SetNull)
  facturaItem       FacturaItem?          @relation(fields: [facturaItemId], references: [id], onDelete: SetNull)
  documentos        PedidoItemDocumento[]
  entregaItems      EntregaItem[]
  materialesCliente MaterialCliente[]

  @@index([pedidoId])
  @@index([itemId])
  @@index([facturaItemId])
  @@index([destinoOperativo])
  @@map("pedido_items")
}

// ------------------------------------------------------------
// PedidoItemDocumento — vínculo entre un ítem del pedido y un documento de referencia
// Permite adjuntar planos, especificaciones o imágenes a ítems específicos del pedido.
// tipoUso: clasificación informal del propósito del documento para ese ítem (libre).
// ------------------------------------------------------------
model PedidoItemDocumento {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoItemId       String   @map("pedido_item_id") @db.Uuid
  documentoId        String   @map("documento_id") @db.Uuid
  tipoUso            String?  @map("tipo_uso") @db.VarChar(80)
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")

  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: Cascade)
  documento  Documento  @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  creadoPor  Usuario?   @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoItemId])
  @@index([documentoId])
  @@map("pedido_item_documentos")
}

// ------------------------------------------------------------
// MaterialCliente — material físico traído por el cliente para ser procesado en Lamicenter
// No afecta inventario de Lamicenter ni genera movimientos de stock.
// Debe ser recibido y validado físicamente antes de comenzar a procesar.
// Los sobrantes pertenecen al cliente; en V1.0 no se controlan salvo PQRS por faltante.
// pedidoItemId: vínculo opcional al ítem del pedido que usa este material.
// Nota: los campos ordenProduccionId y subordenId se agregarán en el Bloque 5.
// ------------------------------------------------------------
model MaterialCliente {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId             String                @map("pedido_id") @db.Uuid
  pedidoItemId         String?               @map("pedido_item_id") @db.Uuid
  tipoMaterial         TipoMaterialCliente   @map("tipo_material")
  descripcion          String                @db.VarChar(500)
  cantidad             Decimal               @db.Decimal(14, 4)
  medidasAproximadas   String?               @map("medidas_aproximadas") @db.VarChar(150)
  estadoFisicoRecibido String?               @map("estado_fisico_recibido") @db.VarChar(255)
  estado               EstadoMaterialCliente @default(PENDIENTE_RECEPCION)
  recibidoPorUsuarioId String?               @map("recibido_por_usuario_id") @db.Uuid
  fechaRecepcion       DateTime?             @map("fecha_recepcion")
  observaciones        String?               @db.Text
  metadata             Json?                 @db.JsonB
  creadoPorUsuarioId   String                @map("creado_por_usuario_id") @db.Uuid
  creadoEn             DateTime              @default(now()) @map("creado_en")
  actualizadoEn        DateTime              @updatedAt @map("actualizado_en")

  pedido      Pedido      @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  pedidoItem  PedidoItem? @relation(fields: [pedidoItemId], references: [id], onDelete: SetNull)
  recibidoPor Usuario?    @relation("MaterialClienteRecibidoPor", fields: [recibidoPorUsuarioId], references: [id], onDelete: SetNull)
  creadoPor   Usuario     @relation("MaterialClienteCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([pedidoItemId])
  @@index([estado])
  @@map("material_cliente")
}

// ------------------------------------------------------------
// ValidacionPedido — proceso formal de validación antes de activar el pedido para producción
// El coordinador revisa que el pedido esté completo, correcto y con documentos suficientes.
// Un pedido puede pasar por múltiples rondas de validación si se rechaza y corrige.
// ------------------------------------------------------------
model ValidacionPedido {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId             String                 @map("pedido_id") @db.Uuid
  validadoPorUsuarioId String?                @map("validado_por_usuario_id") @db.Uuid
  estadoValidacion     EstadoValidacionPedido @default(PENDIENTE) @map("estado_validacion")
  observaciones        String?                @db.Text
  metadata             Json?                  @db.JsonB
  creadoEn             DateTime               @default(now()) @map("creado_en")
  actualizadoEn        DateTime               @updatedAt @map("actualizado_en")

  pedido      Pedido                    @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  validadoPor Usuario?                  @relation(fields: [validadoPorUsuarioId], references: [id], onDelete: SetNull)
  detalles    ValidacionPedidoDetalle[]

  @@index([pedidoId])
  @@index([estadoValidacion])
  @@map("validaciones_pedido")
}

// ------------------------------------------------------------
// ValidacionPedidoDetalle — ítem individual verificado dentro de una validación de pedido
// Registra cada aspecto chequeado y su resultado binario de aprobación.
// ------------------------------------------------------------
model ValidacionPedidoDetalle {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  validacionPedidoId String   @map("validacion_pedido_id") @db.Uuid
  tipoVerificacion   String   @map("tipo_verificacion") @db.VarChar(150)
  aprobado           Boolean
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")

  validacion ValidacionPedido @relation(fields: [validacionPedidoId], references: [id], onDelete: Cascade)

  @@index([validacionPedidoId])
  @@map("validacion_pedido_detalles")
}

// ------------------------------------------------------------
// Entrega — evento de entrega parcial o total de ítems al cliente
// La entrega parcial planeada ocurre cuando el vendedor indica que el cliente retirará
// parte del pedido antes de que se complete todo el proceso.
// Un despacho incompleto (distinto de entrega parcial planeada) puede también generar PQRS.
// contactoClienteId: persona del cliente que recibe físicamente la entrega.
// recibeNombre: nombre libre del receptor si no está registrado como contacto.
// ------------------------------------------------------------
model Entrega {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId              String   @map("pedido_id") @db.Uuid
  contactoClienteId     String?  @map("contacto_cliente_id") @db.Uuid
  entregadoPorUsuarioId String   @map("entregado_por_usuario_id") @db.Uuid
  recibeNombre          String?  @map("recibe_nombre") @db.VarChar(200)
  observaciones         String?  @db.Text
  metadata              Json?    @db.JsonB
  creadoEn              DateTime @default(now()) @map("creado_en")

  pedido          Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  contactoCliente ContactoCliente? @relation(fields: [contactoClienteId], references: [id], onDelete: SetNull)
  entregadoPor    Usuario          @relation(fields: [entregadoPorUsuarioId], references: [id], onDelete: Restrict)
  items           EntregaItem[]

  @@index([pedidoId])
  @@index([contactoClienteId])
  @@map("entregas")
}

// ------------------------------------------------------------
// EntregaItem — detalle de cada ítem incluido en un evento de entrega
// cantidadPendientePosterior: CAMPO CALCULADO INMUTABLE — cantidad que quedó pendiente
// DESPUÉS de esta entrega. Fórmula: cantidadPendiente_antes − cantidadEntregada.
// No se recalcula retroactivamente; es el snapshot inmutable en el momento de la entrega.
// ------------------------------------------------------------
model EntregaItem {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entregaId                  String   @map("entrega_id") @db.Uuid
  pedidoItemId               String   @map("pedido_item_id") @db.Uuid
  cantidadEntregada          Decimal  @map("cantidad_entregada") @db.Decimal(14, 4)
  // CAMPO CALCULADO INMUTABLE: snapshot de cantidad pendiente después de esta entrega
  cantidadPendientePosterior Decimal  @map("cantidad_pendiente_posterior") @db.Decimal(14, 4)
  observaciones              String?  @db.Text
  creadoEn                   DateTime @default(now()) @map("creado_en")

  entrega    Entrega    @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: Restrict)

  @@index([entregaId])
  @@index([pedidoItemId])
  @@map("entrega_items")
}

// ------------------------------------------------------------
// HistorialEstadoPedido — registro inmutable de cada cambio de estado de un pedido
// IMPORTANTE: debe escribirse junto con auditoria_general dentro de la misma transacción
// para garantizar consistencia entre el historial operativo y el registro de auditoría.
// estadoAnteriorId: nullable en la transición inicial (pedido recién creado, sin estado previo).
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model HistorialEstadoPedido {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId           String   @map("pedido_id") @db.Uuid
  estadoAnteriorId   String?  @map("estado_anterior_id") @db.Uuid
  estadoNuevoId      String   @map("estado_nuevo_id") @db.Uuid
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")

  pedido         Pedido         @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  estadoAnterior EstadoSistema? @relation("EstadoAnteriorPedido", fields: [estadoAnteriorId], references: [id], onDelete: SetNull)
  estadoNuevo    EstadoSistema  @relation("EstadoNuevoPedido", fields: [estadoNuevoId], references: [id], onDelete: Restrict)
  creadoPor      Usuario?       @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([estadoNuevoId])
  @@index([creadoEn])
  @@map("historial_estados_pedido")
}

// ------------------------------------------------------------
// AsignacionPedido — historial de asignaciones del pedido a un vendedor
// Al reasignar: NO se sobrescribe el registro anterior.
// Se cierra la asignación activa con fechaFinAsignacion y se crea un nuevo registro.
// La asignación actualmente activa es la que tiene fechaFinAsignacion IS NULL.
// Esto permite auditar todos los cambios de vendedor con motivo y autorizador.
// ------------------------------------------------------------
model AsignacionPedido {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId              String    @map("pedido_id") @db.Uuid
  vendedorId            String    @map("vendedor_id") @db.Uuid
  asignadoPorUsuarioId  String    @map("asignado_por_usuario_id") @db.Uuid
  fechaInicioAsignacion DateTime  @map("fecha_inicio_asignacion")
  fechaFinAsignacion    DateTime? @map("fecha_fin_asignacion")
  motivo                String?   @db.VarChar(500)
  observaciones         String?   @db.Text
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  pedido      Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  vendedor    Usuario @relation("AsignacionVendedor", fields: [vendedorId], references: [id], onDelete: Restrict)
  asignadoPor Usuario @relation("AsignacionRealizadaPor", fields: [asignadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([vendedorId])
  @@index([pedidoId, fechaFinAsignacion])
  @@map("asignaciones_pedido")
}

// ------------------------------------------------------------
// BloqueoPedido — registro de bloqueos activos o históricos de un pedido
// Un pedido bloqueado no puede avanzar en producción ni despacho sin resolución explícita.
// FACTURA_ANULADA: ContaPyme anuló la factura; bloqueo obligatorio hasta revisión del admin.
// bloqueadoPorUsuarioId: nullable si el bloqueo fue generado automáticamente por el sistema.
// fechaDesbloqueo: se llena cuando el administrador resuelve el bloqueo; el registro no se elimina.
// ------------------------------------------------------------
model BloqueoPedido {
  id                       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                 String      @map("pedido_id") @db.Uuid
  tipoBloqueo              TipoBloqueo @map("tipo_bloqueo")
  motivoBloqueo            String      @map("motivo_bloqueo") @db.VarChar(500)
  bloqueadoPorUsuarioId    String?     @map("bloqueado_por_usuario_id") @db.Uuid
  desbloqueadoPorUsuarioId String?     @map("desbloqueado_por_usuario_id") @db.Uuid
  fechaBloqueo             DateTime    @map("fecha_bloqueo")
  fechaDesbloqueo          DateTime?   @map("fecha_desbloqueo")
  observaciones            String?     @db.Text
  metadata                 Json?       @db.JsonB
  creadoEn                 DateTime    @default(now()) @map("creado_en")
  actualizadoEn            DateTime    @updatedAt @map("actualizado_en")

  pedido          Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  bloqueadoPor    Usuario? @relation("BloqueoPedidoCreadoPor", fields: [bloqueadoPorUsuarioId], references: [id], onDelete: SetNull)
  desbloqueadoPor Usuario? @relation("BloqueoPedidoDesbloqueadoPor", fields: [desbloqueadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([tipoBloqueo])
  @@index([fechaDesbloqueo])
  @@map("bloqueos_pedido")
}

// ------------------------------------------------------------
// PedidoSede — historial de traslados o cambios de sede de un pedido
// Registra cada movimiento con trazabilidad completa: solicitante, autorizador, motivo.
// No tiene actualizadoEn: cada evento de movimiento es inmutable.
// Compras debe ser notificado para validar disponibilidad de materiales en la nueva sede.
// ------------------------------------------------------------
model PedidoSede {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId               String             @map("pedido_id") @db.Uuid
  sedeOrigenId           String             @map("sede_origen_id") @db.Uuid
  sedeDestinoId          String             @map("sede_destino_id") @db.Uuid
  tipoMovimientoSede     TipoMovimientoSede @map("tipo_movimiento_sede")
  solicitadoPorUsuarioId String             @map("solicitado_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?            @map("autorizado_por_usuario_id") @db.Uuid
  fechaMovimiento        DateTime           @map("fecha_movimiento")
  observaciones          String             @db.Text
  metadata               Json?              @db.JsonB
  creadoEn               DateTime           @default(now()) @map("creado_en")

  pedido        Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sedeOrigen    Sede     @relation("PedidoSedeOrigen", fields: [sedeOrigenId], references: [id], onDelete: Restrict)
  sedeDestino   Sede     @relation("PedidoSedeDestino", fields: [sedeDestinoId], references: [id], onDelete: Restrict)
  solicitadoPor Usuario  @relation("PedidoSedeSolicitadaPor", fields: [solicitadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor Usuario? @relation("PedidoSedeAutorizadaPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([sedeOrigenId])
  @@index([sedeDestinoId])
  @@map("pedido_sedes")
}

// ------------------------------------------------------------
// FacturaPedido — relación explícita entre facturas y pedidos (pendiente del Bloque 3)
// esPrincipal: identifica la factura principal operativa del pedido. Un pedido debe tener
// una sola factura PRINCIPAL; las adicionales amplían o complementan el alcance.
// La restricción de unicidad de esPrincipal=true por pedido se valida en backend.
// tipoRelacion REEMPLAZO: nueva factura sustituye operativamente a la anterior anulada.
// tipoRelacion DEVOLUCION: nota crédito vinculada al pedido por reclamo o ajuste.
// ------------------------------------------------------------
model FacturaPedido {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facturaId               String                    @map("factura_id") @db.Uuid
  pedidoId                String                    @map("pedido_id") @db.Uuid
  tipoRelacion            TipoRelacionFacturaPedido @map("tipo_relacion")
  esPrincipal             Boolean                   @default(false) @map("es_principal")
  fechaRelacion           DateTime                  @map("fecha_relacion")
  relacionadoPorUsuarioId String                    @map("relacionado_por_usuario_id") @db.Uuid
  observaciones           String?                   @db.Text
  creadoEn                DateTime                  @default(now()) @map("creado_en")
  actualizadoEn           DateTime                  @updatedAt @map("actualizado_en")

  factura        Factura @relation(fields: [facturaId], references: [id], onDelete: Restrict)
  pedido         Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  relacionadoPor Usuario @relation(fields: [relacionadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@unique([facturaId, pedidoId, tipoRelacion])
  @@index([facturaId])
  @@index([pedidoId])
  @@index([esPrincipal])
  @@map("factura_pedido")
}
