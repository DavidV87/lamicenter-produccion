// =============================================================
// Lamicenter — Schema Prisma
// Base de datos: PostgreSQL 18
//
// Convenciones:
//   - Nombres de tablas y campos en español (snake_case en BD)
//   - camelCase en modelos y campos Prisma
//   - UUIDs como identificadores principales (gen_random_uuid)
//   - Sin eliminación física en entidades críticas (activo boolean)
//   - Estados controlados por tablas de máquina de estados
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// BLOQUE 1 — Usuarios, Roles, Permisos, Auditoría, Máquina de Estados
// =============================================================

// ------------------------------------------------------------
// Enum: tipo de acción registrada en auditoría general
// ------------------------------------------------------------
enum TipoAccionAuditoria {
  CREAR
  ACTUALIZAR
  CAMBIO_ESTADO
  AUTORIZACION
  CANCELACION
  REPROCESO
  DESPACHO
  PQRS
  OTRO
}

// ------------------------------------------------------------
// Sedes — instalaciones físicas o sucursales de la empresa
// ------------------------------------------------------------
model Sede {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique @db.VarChar(100)
  direccion     String?  @db.VarChar(255)
  telefono      String?  @db.VarChar(30)
  codigo        String?  @unique @db.VarChar(20)
  correo        String?  @db.VarChar(150)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuarios                        Usuario[]
  maquinas                        Maquina[]
  ubicaciones                     Ubicacion[]
  clientesPrincipales             Cliente[]
  documentos                      Documento[]                @relation("DocumentoSede")
  facturas                        Factura[]                  @relation("FacturaSede")
  pedidosComoVenta                Pedido[]                   @relation("PedidoSedeVenta")
  pedidosComoResponsable          Pedido[]                   @relation("PedidoSedeResponsable")
  pedidosComoDespacho             Pedido[]                   @relation("PedidoSedeDespacho")
  pedidoSedesOrigen               PedidoSede[]               @relation("PedidoSedeOrigen")
  pedidoSedesDestino              PedidoSede[]               @relation("PedidoSedeDestino")
  ordenesProduccionComoProduccion OrdenProduccion[]          @relation("OrdenSedeProduccion")
  ordenesProduccionComoDespacho   OrdenProduccion[]          @relation("OrdenSedeDespacho")
  ordenesProduccionComoActual     OrdenProduccion[]          @relation("OrdenSedeActual")
  subordenesComoProduccion        Suborden[]                 @relation("SubordenSedeProduccion")
  subordenesComoDespacho          Suborden[]                 @relation("SubordenSedeDespacho")
  // Bloque 6 — Abastecimiento
  requerimientosMaterial          RequerimientoMaterial[]
  solicitudesCompra               SolicitudCompra[]
  comprasMaterial                 CompraMaterial[]
  recepcionesMaterial             RecepcionMaterial[]
  trasladosMaterialComoOrigen     TrasladoMaterial[]         @relation("TrasladoSedeOrigen")
  trasladosMaterialComoDestino    TrasladoMaterial[]         @relation("TrasladoSedeDestino")
  movimientosMaterial             MovimientoMaterial[]
  materialesReservados            MaterialReservado[]
  abastecimientoAlertas           AbastecimientoAlerta[]
  inventariosOperativos           InventarioOperativo[]
  // Bloque 7 — Despacho
  despachos                       Despacho[]
  ubicacionesPedido               UbicacionPedido[]
  historialUbicacionesPedido      HistorialUbicacionPedido[]

  @@map("sedes")
}

// ------------------------------------------------------------
// Roles — perfiles de acceso y autorización
// ------------------------------------------------------------
model Rol {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique @db.VarChar(80)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  usuarios                    Usuario[]
  rolesPermisos               RolPermiso[]
  transicionesAutorizadas     TransicionRolAutorizado[]
  // Bloque 8 — Notificaciones y dashboards
  alertasRolesDestino         AlertaRolDestino[]
  eventosNotificacion         EventoNotificacion[]
  configuracionesNotificacion ConfiguracionNotificacion[]
  configuracionesDashboard    ConfiguracionDashboard[]
  configuracionesMetricas     ConfiguracionMetrica[]

  @@map("roles")
}

// ------------------------------------------------------------
// Usuarios — operadores del sistema
// ------------------------------------------------------------
model Usuario {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String    @db.VarChar(150)
  email         String    @unique @db.VarChar(200)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  sedeId        String    @map("sede_id") @db.Uuid
  rolId         String    @map("rol_id") @db.Uuid
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  ultimoAcceso  DateTime? @map("ultimo_acceso")

  sede                                  Sede                        @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  rol                                   Rol                         @relation(fields: [rolId], references: [id], onDelete: Restrict)
  auditorias                            AuditoriaGeneral[]
  documentosCreados                     Documento[]                 @relation("DocumentoCreadoPor")
  versionesSubidas                      DocumentoVersion[]          @relation("VersionSubidaPor")
  facturasComoVendedor                  Factura[]                   @relation("FacturaVendedor")
  facturasCreadas                       Factura[]                   @relation("FacturaCreadaPor")
  itemsMapeados                         FacturaItem[]               @relation("ItemMapeadoPor")
  documentosRelacionados                DocumentoRelacionado[]      @relation("DocumentoRelacionadoPor")
  lecturasDocumento                     LecturaDocumento[]          @relation("LecturaProcesadaPor")
  pedidosComoVendedor                   Pedido[]                    @relation("PedidoVendedor")
  pedidosCreados                        Pedido[]                    @relation("PedidoCreadoPor")
  validacionesPedido                    ValidacionPedido[]
  asignacionesComoVendedor              AsignacionPedido[]          @relation("AsignacionVendedor")
  asignacionesRealizadas                AsignacionPedido[]          @relation("AsignacionRealizadaPor")
  materialesClienteRecibidos            MaterialCliente[]           @relation("MaterialClienteRecibidoPor")
  materialesClienteCreados              MaterialCliente[]           @relation("MaterialClienteCreadoPor")
  bloqueosPedidoCreados                 BloqueoPedido[]             @relation("BloqueoPedidoCreadoPor")
  bloqueosPedidoDesbloqueados           BloqueoPedido[]             @relation("BloqueoPedidoDesbloqueadoPor")
  pedidoSedesSolicitadas                PedidoSede[]                @relation("PedidoSedeSolicitadaPor")
  pedidoSedesAutorizadas                PedidoSede[]                @relation("PedidoSedeAutorizadaPor")
  historialEstadosPedido                HistorialEstadoPedido[]
  entregasRealizadas                    Entrega[]
  facturasPedidoRelacionadas            FacturaPedido[]
  pedidoItemDocumentosCreados           PedidoItemDocumento[]
  ordenesProduccionCreadas              OrdenProduccion[]           @relation("OrdenProduccionCreadaPor")
  subordenesCreadas                     Suborden[]                  @relation("SubordenCreadaPor")
  asignacionesOrdenComoOperador         OrdenAsignacion[]           @relation("OrdenAsignacionOperador")
  asignacionesOrdenRealizadas           OrdenAsignacion[]           @relation("OrdenAsignacionRealizadaPor")
  eventosOperativos                     EventoOperativo[]
  novedadesReportadas                   NovedadOperativa[]
  reprocesosAutorizados                 Reproceso[]                 @relation("ReprocesoAutorizadoPor")
  reprocesosCreados                     Reproceso[]                 @relation("ReprocesoCreadoPor")
  historialEstadosOrden                 HistorialEstadoOrden[]
  historialEstadosSuborden              HistorialEstadoSuborden[]
  calculoPerdidasAutorizados            CalculoPerdidas[]
  // Bloque 6 — Abastecimiento
  requerimientosMaterialCreados         RequerimientoMaterial[]     @relation("RequerimientoMaterialCreadoPor")
  requerimientosMaterialAtendidos       RequerimientoMaterial[]     @relation("RequerimientoMaterialAtendidoPor")
  solicitudesCompraCreadas              SolicitudCompra[]           @relation("SolicitudCompraCreadaPor")
  solicitudesCompraAutorizadas          SolicitudCompra[]           @relation("SolicitudCompraAutorizadaPor")
  comprasMaterialCreadas                CompraMaterial[]            @relation("CompraMaterialCreadaPor")
  comprasMaterialAutorizadas            CompraMaterial[]            @relation("CompraMaterialAutorizadaPor")
  recepcionesRealizadas                 RecepcionMaterial[]
  trasladosMaterialSolicitados          TrasladoMaterial[]          @relation("TrasladoMaterialSolicitadoPor")
  trasladosMaterialAutorizados          TrasladoMaterial[]          @relation("TrasladoMaterialAutorizadoPor")
  movimientosMaterial                   MovimientoMaterial[]
  materialesReservados                  MaterialReservado[]
  abastecimientoAlertasCreadas          AbastecimientoAlerta[]      @relation("AbastecimientoAlertaCreadaPor")
  abastecimientoAlertasCerradas         AbastecimientoAlerta[]      @relation("AbastecimientoAlertaCerradaPor")
  // Bloque 7 — Despacho
  despachosCreados                      Despacho[]                  @relation("DespachoCreadoPor")
  despachosComoEncargado                Despacho[]                  @relation("DespachoEncargadoPor")
  despachosAutorizados                  Despacho[]                  @relation("DespachoAutorizadoPor")
  despachoAutorizaciones                DespachoAutorizacion[]
  checklistsDespachosCompletados        ChecklistDespacho[]
  ubicacionesPedidoActualizadas         UbicacionPedido[]
  historialUbicacionesPedidoRegistradas HistorialUbicacionPedido[]
  evidenciasDespacho                    EvidenciaDespacho[]
  // Bloque 8 — Notificaciones y dashboards
  notificacionesRecibidas               NotificacionUsuario[]       @relation("NotificacionDestinoUsuario")
  notificacionesCreadas                 NotificacionUsuario[]       @relation("NotificacionCreadaPor")
  alertasSistemaCreadas                 AlertaSistema[]
  eventosNotificacionGenerados          EventoNotificacion[]
  configuracionesNotificacion           ConfiguracionNotificacion[]
  historialNotificaciones               HistorialNotificacion[]

  @@index([sedeId])
  @@index([rolId])
  @@index([activo])
  @@map("usuarios")
}

// ------------------------------------------------------------
// Permisos — acciones granulares habilitadas por módulo
// Código usa notación "modulo.accion" (ej: pedidos.crear)
// ------------------------------------------------------------
model Permiso {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo        String   @unique @db.VarChar(100)
  descripcion   String?  @db.Text
  modulo        String   @db.VarChar(80)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  rolesPermisos RolPermiso[]

  @@index([modulo])
  @@map("permisos")
}

// ------------------------------------------------------------
// RolPermiso — asignación de permisos a roles (M:M)
// ------------------------------------------------------------
model RolPermiso {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolId     String   @map("rol_id") @db.Uuid
  permisoId String   @map("permiso_id") @db.Uuid
  creadoEn  DateTime @default(now()) @map("creado_en")

  rol     Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@unique([rolId, permisoId])
  @@map("roles_permisos")
}

// ------------------------------------------------------------
// AuditoriaGeneral — registro inmutable de operaciones críticas
// registroId referencia el UUID del registro afectado en cualquier tabla.
// usuarioId puede ser null cuando la acción es generada por el sistema.
// datosAnteriores / datosNuevos almacenan el snapshot del registro.
// metadata almacena contexto adicional libre según el tipo de acción.
// ------------------------------------------------------------
model AuditoriaGeneral {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tablaAfectada   String              @map("tabla_afectada") @db.VarChar(100)
  registroId      String              @map("registro_id") @db.Uuid
  accion          TipoAccionAuditoria
  datosAnteriores Json?               @map("datos_anteriores") @db.JsonB
  datosNuevos     Json?               @map("datos_nuevos") @db.JsonB
  metadata        Json?               @db.JsonB
  usuarioId       String?             @map("usuario_id") @db.Uuid
  ipOrigen        String?             @map("ip_origen") @db.VarChar(45)
  creadoEn        DateTime            @default(now()) @map("creado_en")
  userAgent       String?             @map("user_agent") @db.VarChar(500)

  usuario Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([tablaAfectada, registroId])
  @@index([usuarioId])
  @@index([accion])
  @@index([creadoEn])
  @@map("auditoria_general")
}

// ------------------------------------------------------------
// EstadoSistema — catálogo de estados por módulo de negocio
// La combinación (modulo, codigo) es única.
// Ejemplos de módulo: pedido, orden_produccion, despacho, pqrs
// ------------------------------------------------------------
model EstadoSistema {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modulo          String   @db.VarChar(80)
  codigo          String   @db.VarChar(80)
  nombre          String   @db.VarChar(100)
  descripcion     String?  @db.Text
  esEstadoInicial Boolean  @default(false) @map("es_estado_inicial")
  esEstadoFinal   Boolean  @default(false) @map("es_estado_final")
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now()) @map("creado_en")
  actualizadoEn   DateTime @updatedAt @map("actualizado_en")

  transicionesComoOrigen      TransicionEstado[]        @relation("EstadoOrigen")
  transicionesComoDestino     TransicionEstado[]        @relation("EstadoDestino")
  pedidos                     Pedido[]                  @relation("PedidoEstado")
  historialAnteriorPedidos    HistorialEstadoPedido[]   @relation("EstadoAnteriorPedido")
  historialNuevoPedidos       HistorialEstadoPedido[]   @relation("EstadoNuevoPedido")
  ordenesProduccion           OrdenProduccion[]         @relation("OrdenEstado")
  subordenes                  Suborden[]                @relation("SubordenEstado")
  ordenEtapas                 OrdenEtapa[]              @relation("OrdenEtapaEstado")
  historialAnteriorOrdenes    HistorialEstadoOrden[]    @relation("EstadoAnteriorOrden")
  historialNuevoOrdenes       HistorialEstadoOrden[]    @relation("EstadoNuevoOrden")
  historialAnteriorSubordenes HistorialEstadoSuborden[] @relation("EstadoAnteriorSuborden")
  historialNuevoSubordenes    HistorialEstadoSuborden[] @relation("EstadoNuevoSuborden")
  // Bloque 6 — Abastecimiento
  requerimientosMaterial      RequerimientoMaterial[]   @relation("RequerimientoEstado")
  solicitudesCompra           SolicitudCompra[]         @relation("SolicitudCompraEstado")
  comprasMaterial             CompraMaterial[]          @relation("CompraEstado")
  recepcionesMaterial         RecepcionMaterial[]       @relation("RecepcionEstado")
  trasladosMaterial           TrasladoMaterial[]        @relation("TrasladoEstado")
  // Bloque 7 — Despacho
  despachos                   Despacho[]                @relation("DespachoEstado")

  @@unique([modulo, codigo])
  @@index([modulo])
  @@map("estados_sistema")
}

// ------------------------------------------------------------
// TransicionEstado — arcos válidos de la máquina de estados
// requiereAutorizacion indica si el rol debe estar en transiciones_roles_autorizados
// ------------------------------------------------------------
model TransicionEstado {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estadoOrigenId       String   @map("estado_origen_id") @db.Uuid
  estadoDestinoId      String   @map("estado_destino_id") @db.Uuid
  nombre               String?  @db.VarChar(150)
  requiereAutorizacion Boolean  @default(false) @map("requiere_autorizacion")
  activo               Boolean  @default(true)
  creadoEn             DateTime @default(now()) @map("creado_en")
  actualizadoEn        DateTime @updatedAt @map("actualizado_en")

  estadoOrigen     EstadoSistema             @relation("EstadoOrigen", fields: [estadoOrigenId], references: [id], onDelete: Restrict)
  estadoDestino    EstadoSistema             @relation("EstadoDestino", fields: [estadoDestinoId], references: [id], onDelete: Restrict)
  rolesAutorizados TransicionRolAutorizado[]

  @@unique([estadoOrigenId, estadoDestinoId])
  @@index([estadoOrigenId])
  @@index([estadoDestinoId])
  @@map("transiciones_estado")
}

// ------------------------------------------------------------
// TransicionRolAutorizado — roles que pueden ejecutar una transición (M:M)
// ------------------------------------------------------------
model TransicionRolAutorizado {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transicionId String   @map("transicion_id") @db.Uuid
  rolId        String   @map("rol_id") @db.Uuid
  creadoEn     DateTime @default(now()) @map("creado_en")

  transicion TransicionEstado @relation(fields: [transicionId], references: [id], onDelete: Cascade)
  rol        Rol              @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([transicionId, rolId])
  @@map("transiciones_roles_autorizados")
}

// =============================================================
// BLOQUE 2 — Catálogos: Items, Clientes, Proveedores, Máquinas, Ubicaciones, Novedades, Documentos
// =============================================================

// ------------------------------------------------------------
// Enum: comportamiento del tipo de ítem
// Determina cómo el sistema trata los ítems de ese tipo.
// Evita el uso de esServicio boolean redundante en el modelo Item.
// ------------------------------------------------------------
enum ComportamientoTipoItem {
  PRODUCTO
  SERVICIO
  MATERIA_PRIMA
  INSUMO
}

// ------------------------------------------------------------
// Enum: unidad de medida estándar del ítem
// Aplica según la naturaleza física del material o servicio.
// M2: tableros y paneles. ML: enchape y tapacanto. UN: piezas y herrajes.
// ------------------------------------------------------------
enum UnidadMedida {
  METRO_CUADRADO
  METRO_LINEAL
  UNIDAD
  HOJA
  KILOGRAMO
  LITRO
  METRO_CUBICO
}

// ------------------------------------------------------------
// Enum: tipo de identificación fiscal o legal
// Aplica a clientes y proveedores, personas naturales o jurídicas.
// ------------------------------------------------------------
enum TipoIdentificacion {
  NIT
  CC
  CE
  PAS
  OTRO
}

// ------------------------------------------------------------
// Enum: categoría principal de un proveedor según lo que suministra
// ------------------------------------------------------------
enum TipoProveedor {
  MATERIAL
  SERVICIO
  TRANSPORTE
  MIXTO
}

// ------------------------------------------------------------
// Enum: entidad del negocio sobre la que aplica un tipo de novedad
// Controla el campo aplica_a en tipos_novedad sin texto libre.
// ------------------------------------------------------------
enum AplicaNovedadA {
  PEDIDO
  ORDEN_PRODUCCION
  SUBORDEN
  DESPACHO
  COMPRA
  MATERIAL
  GENERAL
}

// ------------------------------------------------------------
// TipoItem — catálogo de tipos de ítem que controlan el comportamiento
// El campo comportamiento determina el tratamiento del ítem en el sistema.
// No se usa esServicio en Item: se determina leyendo TipoItem.comportamiento.
// ------------------------------------------------------------
model TipoItem {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre         String                 @unique @db.VarChar(100)
  descripcion    String?                @db.Text
  comportamiento ComportamientoTipoItem
  activo         Boolean                @default(true)
  creadoEn       DateTime               @default(now()) @map("creado_en")
  actualizadoEn  DateTime               @updatedAt @map("actualizado_en")

  items Item[]

  @@map("tipos_item")
}

// ------------------------------------------------------------
// Item — catálogo maestro de ítems (productos, servicios, materias primas)
// precioVentaReferencia y costoReferencia son referenciales, no de facturación.
// controlaInventario: activa movimientos de stock para este ítem.
// requiereCorte: indica que el ítem es procesado por maquinaria CNC.
// metadata: atributos flexibles adicionales (color, textura, dimensiones, marca).
// ------------------------------------------------------------
model Item {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoItemId            String       @map("tipo_item_id") @db.Uuid
  codigo                String       @unique @db.VarChar(80)
  nombre                String       @db.VarChar(200)
  descripcion           String?      @db.Text
  unidadMedida          UnidadMedida @map("unidad_medida")
  precioVentaReferencia Decimal?     @map("precio_venta_referencia") @db.Decimal(14, 4)
  costoReferencia       Decimal?     @map("costo_referencia") @db.Decimal(14, 4)
  controlaInventario    Boolean      @default(false) @map("controla_inventario")
  requiereCorte         Boolean      @default(false) @map("requiere_corte")
  permiteFraccion       Boolean      @default(false) @map("permite_fraccion")
  metadata              Json?        @db.JsonB
  activo                Boolean      @default(true)
  creadoEn              DateTime     @default(now()) @map("creado_en")
  actualizadoEn         DateTime     @updatedAt @map("actualizado_en")

  tipoItem                TipoItem                @relation(fields: [tipoItemId], references: [id], onDelete: Restrict)
  facturaItems            FacturaItem[]
  pedidoItems             PedidoItem[]
  reprocesosComoOrigen    Reproceso[]             @relation("ReprocesoItemOrigen")
  reprocesosComoUtilizado Reproceso[]             @relation("ReprocesoItemUtilizado")
  // Bloque 6 — Abastecimiento
  requerimientosMaterial  RequerimientoMaterial[]
  solicitudCompraItems    SolicitudCompraItem[]
  compraItems             CompraItemMaterial[]
  recepcionItems          RecepcionItemMaterial[]
  trasladoItems           TrasladoItemMaterial[]
  movimientosMaterial     MovimientoMaterial[]
  materialesReservados    MaterialReservado[]
  abastecimientoAlertas   AbastecimientoAlerta[]
  inventariosOperativos   InventarioOperativo[]

  @@index([codigo])
  @@index([tipoItemId])
  @@index([activo])
  @@map("items")
}

// ------------------------------------------------------------
// Cliente — personas naturales o empresas que realizan pedidos
// La identificacion es única para prevenir duplicados en el sistema.
// Un cliente puede tener múltiples contactos a través de contactos_cliente.
// ------------------------------------------------------------
model Cliente {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  razonSocial        String             @map("razon_social") @db.VarChar(200)
  nombreComercial    String?            @map("nombre_comercial") @db.VarChar(200)
  identificacion     String             @unique @db.VarChar(30)
  tipoIdentificacion TipoIdentificacion @map("tipo_identificacion")
  sedePrincipalId    String?            @map("sede_principal_id") @db.Uuid
  telefono           String?            @db.VarChar(30)
  correo             String?            @db.VarChar(150)
  direccion          String?            @db.VarChar(255)
  ciudad             String?            @db.VarChar(100)
  activo             Boolean            @default(true)
  creadoEn           DateTime           @default(now()) @map("creado_en")
  actualizadoEn      DateTime           @updatedAt @map("actualizado_en")

  sedePrincipal Sede?             @relation(fields: [sedePrincipalId], references: [id], onDelete: SetNull)
  contactos     ContactoCliente[]
  facturas      Factura[]         @relation("FacturaCliente")
  pedidos       Pedido[]

  @@index([sedePrincipalId])
  @@index([activo])
  @@map("clientes")
}

// ------------------------------------------------------------
// ContactoCliente — personas de contacto vinculadas a un cliente
// esPrincipal identifica el contacto preferido para comunicaciones.
// La eliminación del cliente propaga en cascada a sus contactos.
// ------------------------------------------------------------
model ContactoCliente {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clienteId     String   @map("cliente_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  cargo         String?  @db.VarChar(100)
  telefono      String?  @db.VarChar(30)
  correo        String?  @db.VarChar(150)
  esPrincipal   Boolean  @default(false) @map("es_principal")
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  cliente  Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  entregas Entrega[]

  @@index([clienteId])
  @@map("contactos_cliente")
}

// ------------------------------------------------------------
// Proveedor — empresas o personas que suministran materiales o servicios
// La identificacion es única para prevenir duplicados en el sistema.
// ------------------------------------------------------------
model Proveedor {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  razonSocial        String             @map("razon_social") @db.VarChar(200)
  nombreComercial    String?            @map("nombre_comercial") @db.VarChar(200)
  identificacion     String             @unique @db.VarChar(30)
  tipoIdentificacion TipoIdentificacion @map("tipo_identificacion")
  tipoProveedor      TipoProveedor      @map("tipo_proveedor")
  telefono           String?            @db.VarChar(30)
  correo             String?            @db.VarChar(150)
  direccion          String?            @db.VarChar(255)
  ciudad             String?            @db.VarChar(100)
  activo             Boolean            @default(true)
  creadoEn           DateTime           @default(now()) @map("creado_en")
  actualizadoEn      DateTime           @updatedAt @map("actualizado_en")

  // Bloque 6 — Abastecimiento
  solicitudesCompra SolicitudCompra[]
  comprasMaterial   CompraMaterial[]

  @@index([activo])
  @@index([tipoProveedor])
  @@map("proveedores")
}

// ------------------------------------------------------------
// Maquina — equipos productivos registrados por sede
// sedeId es obligatorio: toda máquina debe pertenecer a una sede física.
// ------------------------------------------------------------
model Maquina {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId        String   @map("sede_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  codigo        String   @unique @db.VarChar(50)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  sede              Sede              @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ordenesProduccion OrdenProduccion[] @relation("OrdenMaquinaPrincipal")
  asignacionesOrden OrdenAsignacion[]

  @@index([sedeId])
  @@index([activo])
  @@map("maquinas")
}

// ------------------------------------------------------------
// Ubicacion — espacios físicos de almacenamiento o proceso por sede
// Permite trazar la posición de materiales y productos en proceso.
// sedeId es obligatorio: toda ubicación pertenece a una sede física.
// ------------------------------------------------------------
model Ubicacion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeId        String   @map("sede_id") @db.Uuid
  nombre        String   @db.VarChar(150)
  codigo        String   @unique @db.VarChar(50)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  sede                       Sede                       @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  // Bloque 6 — Abastecimiento
  recepcionItems             RecepcionItemMaterial[]
  trasladoItems              TrasladoItemMaterial[]
  movimientosMaterial        MovimientoMaterial[]
  materialesReservados       MaterialReservado[]
  inventariosOperativos      InventarioOperativo[]
  // Bloque 7 — Despacho
  ubicacionesPedido          UbicacionPedido[]
  historialUbicacionesPedido HistorialUbicacionPedido[]

  @@index([sedeId])
  @@index([activo])
  @@map("ubicaciones")
}

// ------------------------------------------------------------
// TipoNovedad — catálogo de tipos de novedad operativa
// aplicaA define la entidad del sistema afectada, controlado por enum.
// No se usa texto libre para garantizar integridad del catálogo.
// ------------------------------------------------------------
model TipoNovedad {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String         @unique @db.VarChar(100)
  descripcion   String?        @db.Text
  aplicaA       AplicaNovedadA @map("aplica_a")
  activo        Boolean        @default(true)
  creadoEn      DateTime       @default(now()) @map("creado_en")
  actualizadoEn DateTime       @updatedAt @map("actualizado_en")

  novedadesOperativas NovedadOperativa[]

  @@index([aplicaA])
  @@map("tipos_novedad")
}

// ------------------------------------------------------------
// TipoDocumento — catálogo de tipos de documento del sistema
// Ejemplos de uso: FACTURA, REMISION, ORDEN_COMPRA, COTIZACION, PLANO_CORTE
// codigo es el identificador corto para referencias internas y reportes.
// ------------------------------------------------------------
model TipoDocumento {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre                 String   @unique @db.VarChar(100)
  codigo                 String   @unique @db.VarChar(30)
  descripcion            String?  @db.Text
  requiereVersionamiento Boolean  @default(false) @map("requiere_versionamiento")
  activo                 Boolean  @default(true)
  creadoEn               DateTime @default(now()) @map("creado_en")
  actualizadoEn          DateTime @updatedAt @map("actualizado_en")

  documentos Documento[]

  @@map("tipos_documento")
}

// =============================================================
// BLOQUE 3 — Documentos, Facturas y Versionamiento
// =============================================================

// ------------------------------------------------------------
// Enum: estado de mapeo de un ítem de factura hacia el catálogo interno
// PENDIENTE: aún no procesado.
// MAPEADO_AUTOMATICO: el parser identificó y asoció el ítem automáticamente.
// MAPEADO_MANUAL: un usuario asoció el ítem manualmente desde la interfaz.
// REQUIERE_REVISION: el parser dudó; necesita confirmación humana antes de continuar.
// IGNORADO: el ítem no aplica para producción (descuento, flete, impuesto extra).
// ------------------------------------------------------------
enum EstadoMapeo {
  PENDIENTE
  MAPEADO_AUTOMATICO
  MAPEADO_MANUAL
  REQUIERE_REVISION
  IGNORADO
}

// ------------------------------------------------------------
// Enum: modalidad de pago registrada en la factura comercial
// ------------------------------------------------------------
enum TipoPago {
  CONTADO
  CREDITO
  CHEQUE
  TRANSFERENCIA
  MIXTO
}

// ------------------------------------------------------------
// Enum: estado de cobro de la factura
// VENCIDO: crédito superó la fecha de vencimiento sin pago total.
// ------------------------------------------------------------
enum EstadoPago {
  PENDIENTE
  PARCIAL
  PAGADO
  VENCIDO
  ANULADO
}

// ------------------------------------------------------------
// Enum: estado operativo de la factura dentro del sistema
// BLOQUEADA: factura anulada en ContaPyme; requiere revisión del administrador de punto.
// REEMPLAZADA: sustituida por otra factura dentro del mismo pedido.
// ------------------------------------------------------------
enum EstadoFactura {
  ACTIVA
  PENDIENTE_REVISION
  BLOQUEADA
  ANULADA
  REEMPLAZADA
}

// ------------------------------------------------------------
// Enum: tipo de relación semántica entre dos documentos
// Permite trazar vínculos: factura↔plano, factura↔nota crédito, reemplazo, etc.
// ------------------------------------------------------------
enum TipoRelacionDocumento {
  FACTURA_PLANO
  NOTA_CREDITO
  VERSION
  COMPLEMENTO
  REEMPLAZO
  ANULACION
  REFERENCIA
}

// ------------------------------------------------------------
// Enum: estado del ciclo de vida del proceso de lectura/parsing de una versión
// REVISION_MANUAL: el parser no pudo completar la lectura; requiere intervención humana.
// ------------------------------------------------------------
enum EstadoLecturaDocumento {
  PENDIENTE
  EN_PROCESO
  EXITOSA
  FALLIDA
  REVISION_MANUAL
}

// ------------------------------------------------------------
// Enum: servicio o método que procesó la lectura del documento
// OCR_CONTPYME: lectura automática de facturas exportadas desde ContaPyme.
// PARSER_CUTLIST: parsing automático de planos CutList.
// IMPORTADOR_MANUAL: carga realizada directamente por un usuario desde la interfaz.
// ------------------------------------------------------------
enum ServicioLectura {
  OCR_CONTPYME
  PARSER_CUTLIST
  IMPORTADOR_MANUAL
}

// ------------------------------------------------------------
// Documento — contenedor lógico que agrupa versiones de un archivo
// Puede representar: factura, plano CutList, nota crédito, remisión, cotización, etc.
// No almacena archivos físicos: los archivos van en documentos_versiones (inmutables).
// tipoDocumentoId clasifica el documento según el catálogo tipos_documento del bloque 2.
// activo: soft delete; los documentos críticos no se eliminan físicamente.
// metadata: campos adicionales flexibles según el tipo de documento.
// ------------------------------------------------------------
model Documento {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoDocumentoId    String   @map("tipo_documento_id") @db.Uuid
  titulo             String   @db.VarChar(200)
  descripcion        String?  @db.Text
  sedeId             String?  @map("sede_id") @db.Uuid
  creadoPorUsuarioId String   @map("creado_por_usuario_id") @db.Uuid
  activo             Boolean  @default(true)
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  tipoDocumento        TipoDocumento          @relation(fields: [tipoDocumentoId], references: [id], onDelete: Restrict)
  sede                 Sede?                  @relation("DocumentoSede", fields: [sedeId], references: [id], onDelete: SetNull)
  creadoPor            Usuario                @relation("DocumentoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  versiones            DocumentoVersion[]
  factura              Factura?
  relacionesOrigen     DocumentoRelacionado[] @relation("DocumentoOrigen")
  relacionesDestino    DocumentoRelacionado[] @relation("DocumentoDestino")
  pedidoItemDocumentos PedidoItemDocumento[]

  @@index([tipoDocumentoId])
  @@index([sedeId])
  @@index([creadoPorUsuarioId])
  @@index([activo])
  @@map("documentos")
}

// ------------------------------------------------------------
// DocumentoVersion — versión inmutable de un archivo físico asociado a un documento
// Cada carga genera una nueva versión; nunca se reemplaza ni elimina la versión anterior.
// version: entero incremental por documento (1, 2, 3...); único por documento.
// hashArchivo: sha256/md5 opcional para verificar integridad y detectar duplicados.
// rutaArchivo: ruta de almacenamiento interno; no es URL pública directa.
// pesoBytes: BigInt para soportar archivos de hasta varios GB sin desbordamiento.
// No tiene actualizadoEn: la inmutabilidad garantiza que el registro no cambia.
// ------------------------------------------------------------
model DocumentoVersion {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId        String   @map("documento_id") @db.Uuid
  version            Int
  rutaArchivo        String   @map("ruta_archivo") @db.VarChar(500)
  nombreOriginal     String   @map("nombre_original") @db.VarChar(255)
  extension          String   @db.VarChar(20)
  mimeType           String   @map("mime_type") @db.VarChar(100)
  pesoBytes          BigInt   @map("peso_bytes")
  hashArchivo        String?  @map("hash_archivo") @db.VarChar(128)
  subidoPorUsuarioId String   @map("subido_por_usuario_id") @db.Uuid
  creadoEn           DateTime @default(now()) @map("creado_en")

  documento Documento          @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  subidoPor Usuario            @relation("VersionSubidaPor", fields: [subidoPorUsuarioId], references: [id], onDelete: Restrict)
  lecturas  LecturaDocumento[]

  @@unique([documentoId, version])
  @@index([documentoId])
  @@index([subidoPorUsuarioId])
  @@map("documentos_versiones")
}

// ------------------------------------------------------------
// Factura — factura comercial leída desde ContaPyme o importada como PDF
// documentoId es unique: cada factura corresponde a un único documento lógico.
// vendedorId es nullable: puede no conocerse en facturas históricas importadas.
// creadoPorUsuarioId: auditoría de quién registró la factura en el sistema.
// saldoPendiente: se actualiza cuando se registran abonos (total − suma de abonos).
// estadoFactura BLOQUEADA: anulación en ContaPyme obliga revisión antes de continuar producción.
// metadata: preserva campos adicionales del sistema ContaPyme u otras fuentes externas.
// Si el parser falla, el operador puede completar o corregir todos los campos manualmente.
// ------------------------------------------------------------
model Factura {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoId        String        @unique @map("documento_id") @db.Uuid
  sedeId             String        @map("sede_id") @db.Uuid
  clienteId          String        @map("cliente_id") @db.Uuid
  vendedorId         String?       @map("vendedor_id") @db.Uuid
  creadoPorUsuarioId String?       @map("creado_por_usuario_id") @db.Uuid
  numeroFactura      String        @unique @map("numero_factura") @db.VarChar(50)
  fechaFactura       DateTime      @map("fecha_factura") @db.Date
  tipoPago           TipoPago      @map("tipo_pago")
  estadoPago         EstadoPago    @default(PENDIENTE) @map("estado_pago")
  estadoFactura      EstadoFactura @default(ACTIVA) @map("estado_factura")
  subtotal           Decimal       @db.Decimal(16, 4)
  impuestos          Decimal       @db.Decimal(16, 4)
  total              Decimal       @db.Decimal(16, 4)
  saldoPendiente     Decimal       @map("saldo_pendiente") @db.Decimal(16, 4)
  // Origen del saldo pendiente: CONTAPYME (sincronizado), MANUAL (ingresado por usuario), CALCULADO (derivado de abonos registrados)
  fuenteSaldo        String?       @map("fuente_saldo") @db.VarChar(50)
  metadata           Json?         @db.JsonB
  creadoEn           DateTime      @default(now()) @map("creado_en")
  actualizadoEn      DateTime      @updatedAt @map("actualizado_en")

  documento      Documento       @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  sede           Sede            @relation("FacturaSede", fields: [sedeId], references: [id], onDelete: Restrict)
  cliente        Cliente         @relation("FacturaCliente", fields: [clienteId], references: [id], onDelete: Restrict)
  vendedor       Usuario?        @relation("FacturaVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  creadoPor      Usuario?        @relation("FacturaCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)
  items          FacturaItem[]
  facturasPedido FacturaPedido[]

  @@index([sedeId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estadoFactura])
  @@index([estadoPago])
  @@index([fechaFactura])
  @@map("facturas")
}

// ------------------------------------------------------------
// FacturaItem — línea de detalle de una factura
// descripcionOriginal: texto tal como viene del PDF o ContaPyme, sin modificar.
// itemId es nullable: el ítem puede no existir en catálogo aún (estadoMapeo PENDIENTE).
// codigoOriginal / unidadOriginal: valores crudos del documento fuente para trazabilidad.
// estadoMapeo controla el flujo de asociación entre el texto original y el catálogo de ítems.
// mapeadoPorUsuarioId + fechaMapeo: trazabilidad completa del proceso de mapeo.
// IGNORADO: ítems no aplicables a producción (descuentos, fletes, impuestos adicionales).
// El operador puede continuar operación sin bloquear producción aunque haya ítems PENDIENTE.
// ------------------------------------------------------------
model FacturaItem {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facturaId           String      @map("factura_id") @db.Uuid
  itemId              String?     @map("item_id") @db.Uuid
  descripcionOriginal String      @map("descripcion_original") @db.VarChar(500)
  codigoOriginal      String?     @map("codigo_original") @db.VarChar(100)
  unidadOriginal      String?     @map("unidad_original") @db.VarChar(50)
  cantidad            Decimal     @db.Decimal(14, 4)
  precioUnitario      Decimal     @map("precio_unitario") @db.Decimal(14, 4)
  subtotal            Decimal     @db.Decimal(14, 4)
  estadoMapeo         EstadoMapeo @default(PENDIENTE) @map("estado_mapeo")
  mapeadoPorUsuarioId String?     @map("mapeado_por_usuario_id") @db.Uuid
  fechaMapeo          DateTime?   @map("fecha_mapeo")
  observaciones       String?     @db.Text
  creadoEn            DateTime    @default(now()) @map("creado_en")
  actualizadoEn       DateTime    @updatedAt @map("actualizado_en")

  factura     Factura      @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  item        Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  mapeadoPor  Usuario?     @relation("ItemMapeadoPor", fields: [mapeadoPorUsuarioId], references: [id], onDelete: SetNull)
  pedidoItems PedidoItem[]

  @@index([facturaId])
  @@index([itemId])
  @@index([estadoMapeo])
  @@index([mapeadoPorUsuarioId])
  @@map("factura_items")
}

// ------------------------------------------------------------
// DocumentoRelacionado — vínculo explícito entre dos documentos
// Permite trazar relaciones semánticas: factura↔plano, factura↔nota crédito, etc.
// El único en [origen, destino, tipoRelacion] previene relaciones duplicadas del mismo tipo.
// documentoOrigenId ≠ documentoDestinoId: validar en backend que no se relacione consigo mismo.
// ------------------------------------------------------------
model DocumentoRelacionado {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoOrigenId       String                @map("documento_origen_id") @db.Uuid
  documentoDestinoId      String                @map("documento_destino_id") @db.Uuid
  tipoRelacion            TipoRelacionDocumento @map("tipo_relacion")
  relacionadoPorUsuarioId String?               @map("relacionado_por_usuario_id") @db.Uuid
  observaciones           String?               @db.Text
  creadoEn                DateTime              @default(now()) @map("creado_en")

  documentoOrigen  Documento @relation("DocumentoOrigen", fields: [documentoOrigenId], references: [id], onDelete: Restrict)
  documentoDestino Documento @relation("DocumentoDestino", fields: [documentoDestinoId], references: [id], onDelete: Restrict)
  relacionadoPor   Usuario?  @relation("DocumentoRelacionadoPor", fields: [relacionadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@unique([documentoOrigenId, documentoDestinoId, tipoRelacion])
  @@index([documentoOrigenId])
  @@index([documentoDestinoId])
  @@map("documentos_relacionados")
}

// ------------------------------------------------------------
// LecturaDocumento — registro de cada intento de procesamiento automático o manual de una versión
// Separa el procesador humano (procesadoPorUsuarioId) del servicio automático (procesadoPorServicio).
// Solo uno debe estar activo por lectura; validar en backend que no coexistan ambos.
// resultadoLectura: estructura JSON extraída por el parser (campos de factura, ítems de plano, etc.).
// intentos: contador de reintentos automáticos antes de escalar a REVISION_MANUAL.
// errorDetalle: texto del error si el procesamiento falló; facilita diagnóstico y soporte.
// El fallback manual está siempre disponible; la operación no se bloquea por fallo del parser.
// ------------------------------------------------------------
model LecturaDocumento {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentoVersionId    String                 @map("documento_version_id") @db.Uuid
  estadoLectura         EstadoLecturaDocumento @default(PENDIENTE) @map("estado_lectura")
  procesadoPorUsuarioId String?                @map("procesado_por_usuario_id") @db.Uuid
  procesadoPorServicio  ServicioLectura?       @map("procesado_por_servicio")
  resultadoLectura      Json?                  @map("resultado_lectura") @db.JsonB
  errorDetalle          String?                @map("error_detalle") @db.Text
  intentos              Int                    @default(0)
  fechaInicio           DateTime?              @map("fecha_inicio")
  fechaFin              DateTime?              @map("fecha_fin")
  metadata              Json?                  @db.JsonB
  creadoEn              DateTime               @default(now()) @map("creado_en")
  actualizadoEn         DateTime               @updatedAt @map("actualizado_en")

  documentoVersion    DocumentoVersion @relation(fields: [documentoVersionId], references: [id], onDelete: Restrict)
  procesadoPorUsuario Usuario?         @relation("LecturaProcesadaPor", fields: [procesadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([documentoVersionId])
  @@index([estadoLectura])
  @@index([procesadoPorUsuarioId])
  @@map("lectura_documentos")
}

// =============================================================
// BLOQUE 4 — Pedidos y Estructura Operativa
// =============================================================

// ------------------------------------------------------------
// Enum: destino operativo de un ítem dentro del pedido
// PRODUCCION: entra al flujo de corte/enchape/perforación en planta.
// DESPACHO_DIRECTO: sale sin pasar por producción (ej: herraje, tablero entero).
// MATERIAL_CLIENTE: material físico que trajo el cliente; no afecta inventario Lamicenter.
// SERVICIO: proceso que no requiere producción en planta (ej: instalación, asesoría).
// ------------------------------------------------------------
enum DestinoOperativo {
  PRODUCCION
  DESPACHO_DIRECTO
  MATERIAL_CLIENTE
  SERVICIO
}

// ------------------------------------------------------------
// Enum: tipo de material físico que el cliente trae a Lamicenter para procesar
// ------------------------------------------------------------
enum TipoMaterialCliente {
  TABLERO
  TAPA
  RETAL
  HERRAJE
  INSUMO
}

// ------------------------------------------------------------
// Enum: estado físico y operativo del material cliente en el sistema
// PENDIENTE_RECEPCION: registrado pero aún no recibido físicamente.
// EN_PROCESO: siendo usado o en espera dentro de producción.
// ------------------------------------------------------------
enum EstadoMaterialCliente {
  PENDIENTE_RECEPCION
  RECIBIDO
  EN_PROCESO
  DEVUELTO
  EXTRAVIADO
}

// ------------------------------------------------------------
// Enum: resultado del proceso de validación de un pedido antes de activarlo para producción
// REQUIERE_AJUSTE: el coordinador detectó inconsistencias que el vendedor debe corregir.
// ------------------------------------------------------------
enum EstadoValidacionPedido {
  PENDIENTE
  APROBADA
  RECHAZADA
  REQUIERE_AJUSTE
}

// ------------------------------------------------------------
// Enum: tipo de movimiento de sede registrado en el historial de traslados del pedido
// ------------------------------------------------------------
enum TipoMovimientoSede {
  TRASLADO_PRODUCCION
  TRASLADO_DESPACHO
  DEVOLUCION_SEDE_ORIGEN
  ASIGNACION_INICIAL
  CAMBIO_RESPONSABLE
}

// ------------------------------------------------------------
// Enum: tipo de relación entre una factura y un pedido
// Corresponde a los tipos definidos en la decisión técnica del Bloque 3/4.
// REEMPLAZO: la nueva factura sustituye operativamente a la anterior anulada.
// DEVOLUCION: nota crédito asociada al pedido por reclamo o ajuste.
// ------------------------------------------------------------
enum TipoRelacionFacturaPedido {
  PRINCIPAL
  ADICIONAL
  REEMPLAZO
  DEVOLUCION
  COMPLEMENTO
}

// ------------------------------------------------------------
// Enum: motivo del bloqueo de un pedido
// FACTURA_ANULADA: ContaPyme anuló la factura asociada; requiere revisión obligatoria.
// REVISION_ADMINISTRATIVA: bloqueo manual por el administrador de punto.
// ------------------------------------------------------------
enum TipoBloqueo {
  FACTURA_ANULADA
  PAGO_VENCIDO
  REVISION_ADMINISTRATIVA
  PENDIENTE_AUTORIZACION
  MANUAL
}

// ------------------------------------------------------------
// Pedido — registro central de una solicitud de trabajo para un cliente
// estadoPedidoId: FK a estados_sistema (no enum libre); permite configuración
// dinámica de estados sin migraciones adicionales.
// sedeVentaId: sede donde el vendedor registró el pedido comercialmente.
// sedeResponsableId: sede operativamente responsable del pedido.
// sedeDespachoId: sede donde se entregará; nullable si aún no está definida.
// fechaListoDespacho: desnormalizado para métricas rápidas de tiempo terminado vs recogido.
// fechaDespachoCompleto: desnormalizado; refleja cuándo el pedido salió completo.
// vendedorId: nullable; puede reasignarse. Historial en asignaciones_pedido.
// ------------------------------------------------------------
model Pedido {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sedeVentaId           String    @map("sede_venta_id") @db.Uuid
  sedeResponsableId     String    @map("sede_responsable_id") @db.Uuid
  sedeDespachoId        String?   @map("sede_despacho_id") @db.Uuid
  clienteId             String    @map("cliente_id") @db.Uuid
  vendedorId            String?   @map("vendedor_id") @db.Uuid
  creadoPorUsuarioId    String    @map("creado_por_usuario_id") @db.Uuid
  estadoPedidoId        String    @map("estado_pedido_id") @db.Uuid
  observaciones         String?   @db.Text
  fechaListoDespacho    DateTime? @map("fecha_listo_despacho")
  fechaDespachoCompleto DateTime? @map("fecha_despacho_completo")
  metadata              Json?     @db.JsonB
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  sedeVenta              Sede                       @relation("PedidoSedeVenta", fields: [sedeVentaId], references: [id], onDelete: Restrict)
  sedeResponsable        Sede                       @relation("PedidoSedeResponsable", fields: [sedeResponsableId], references: [id], onDelete: Restrict)
  sedeDespacho           Sede?                      @relation("PedidoSedeDespacho", fields: [sedeDespachoId], references: [id], onDelete: SetNull)
  cliente                Cliente                    @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  vendedor               Usuario?                   @relation("PedidoVendedor", fields: [vendedorId], references: [id], onDelete: SetNull)
  creadoPor              Usuario                    @relation("PedidoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  estadoPedido           EstadoSistema              @relation("PedidoEstado", fields: [estadoPedidoId], references: [id], onDelete: Restrict)
  items                  PedidoItem[]
  materialesCliente      MaterialCliente[]
  validaciones           ValidacionPedido[]
  entregas               Entrega[]
  historialEstados       HistorialEstadoPedido[]
  asignaciones           AsignacionPedido[]
  bloqueos               BloqueoPedido[]
  sedes                  PedidoSede[]
  facturasPedido         FacturaPedido[]
  ordenesProduccion      OrdenProduccion[]
  subordenes             Suborden[]
  reprocesosComoOrigen   Reproceso[]                @relation("ReprocesoOrigenPedido")
  // Bloque 6 — Abastecimiento
  movimientosMaterial    MovimientoMaterial[]
  materialesReservados   MaterialReservado[]
  requerimientosMaterial RequerimientoMaterial[]
  // Bloque 7 — Despacho
  despachos              Despacho[]
  ubicacionActual        UbicacionPedido?
  historialUbicaciones   HistorialUbicacionPedido[]

  @@index([sedeVentaId])
  @@index([sedeResponsableId])
  @@index([clienteId])
  @@index([vendedorId])
  @@index([estadoPedidoId])
  @@map("pedidos")
}

// ------------------------------------------------------------
// PedidoItem — línea de ítem dentro de un pedido
// cantidadPendiente: CAMPO CALCULADO INMUTABLE — captura la cantidad pendiente en el momento
// del evento que genera el registro. No se recalcula retroactivamente; es un snapshot inmutable.
// cantidadParaProduccion: porción del ítem que entra al flujo de producción en planta.
// cantidadParaDespachoEntero: porción que se despacha sin procesamiento adicional.
// facturaItemId: trazabilidad del ítem de factura origen que dio lugar a esta línea del pedido.
// esMaterialCliente: indica que el ítem corresponde a material traído por el cliente.
// ------------------------------------------------------------
model PedidoItem {
  id                         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                   String           @map("pedido_id") @db.Uuid
  itemId                     String?          @map("item_id") @db.Uuid
  facturaItemId              String?          @map("factura_item_id") @db.Uuid
  descripcion                String           @db.VarChar(500)
  cantidad                   Decimal          @db.Decimal(14, 4)
  cantidadTotal              Decimal          @map("cantidad_total") @db.Decimal(14, 4)
  cantidadParaProduccion     Decimal          @map("cantidad_para_produccion") @db.Decimal(14, 4)
  cantidadParaDespachoEntero Decimal          @map("cantidad_para_despacho_entero") @db.Decimal(14, 4)
  // CAMPO CALCULADO INMUTABLE: snapshot de cantidad pendiente al momento del evento que lo genera
  cantidadPendiente          Decimal          @map("cantidad_pendiente") @db.Decimal(14, 4)
  precioUnitario             Decimal?         @map("precio_unitario") @db.Decimal(14, 4)
  destinoOperativo           DestinoOperativo @map("destino_operativo")
  esMaterialCliente          Boolean          @default(false) @map("es_material_cliente")
  observaciones              String?          @db.Text
  metadata                   Json?            @db.JsonB
  creadoEn                   DateTime         @default(now()) @map("creado_en")
  actualizadoEn              DateTime         @updatedAt @map("actualizado_en")

  pedido            Pedido                @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  item              Item?                 @relation(fields: [itemId], references: [id], onDelete: SetNull)
  facturaItem       FacturaItem?          @relation(fields: [facturaItemId], references: [id], onDelete: SetNull)
  documentos        PedidoItemDocumento[]
  entregaItems      EntregaItem[]
  materialesCliente MaterialCliente[]
  // Bloque 7 — Despacho
  despachoItems     DespachoItem[]

  @@index([pedidoId])
  @@index([itemId])
  @@index([facturaItemId])
  @@index([destinoOperativo])
  @@map("pedido_items")
}

// ------------------------------------------------------------
// PedidoItemDocumento — vínculo entre un ítem del pedido y un documento de referencia
// Permite adjuntar planos, especificaciones o imágenes a ítems específicos del pedido.
// tipoUso: clasificación informal del propósito del documento para ese ítem (libre).
// ------------------------------------------------------------
model PedidoItemDocumento {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoItemId       String   @map("pedido_item_id") @db.Uuid
  documentoId        String   @map("documento_id") @db.Uuid
  tipoUso            String?  @map("tipo_uso") @db.VarChar(80)
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")

  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: Cascade)
  documento  Documento  @relation(fields: [documentoId], references: [id], onDelete: Restrict)
  creadoPor  Usuario?   @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoItemId])
  @@index([documentoId])
  @@map("pedido_item_documentos")
}

// ------------------------------------------------------------
// MaterialCliente — material físico traído por el cliente para ser procesado en Lamicenter
// No afecta inventario de Lamicenter ni genera movimientos de stock.
// Debe ser recibido y validado físicamente antes de comenzar a procesar.
// Los sobrantes pertenecen al cliente; en V1.0 no se controlan salvo PQRS por faltante.
// pedidoItemId: vínculo opcional al ítem del pedido que usa este material.
// ordenProduccionId: orden de producción que procesa este material (nullable).
// subordenId: suborden que procesa este material (nullable).
// ------------------------------------------------------------
model MaterialCliente {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId             String                @map("pedido_id") @db.Uuid
  pedidoItemId         String?               @map("pedido_item_id") @db.Uuid
  ordenProduccionId    String?               @map("orden_produccion_id") @db.Uuid
  subordenId           String?               @map("suborden_id") @db.Uuid
  tipoMaterial         TipoMaterialCliente   @map("tipo_material")
  descripcion          String                @db.VarChar(500)
  cantidad             Decimal               @db.Decimal(14, 4)
  medidasAproximadas   String?               @map("medidas_aproximadas") @db.VarChar(150)
  estadoFisicoRecibido String?               @map("estado_fisico_recibido") @db.VarChar(255)
  estado               EstadoMaterialCliente @default(PENDIENTE_RECEPCION)
  recibidoPorUsuarioId String?               @map("recibido_por_usuario_id") @db.Uuid
  fechaRecepcion       DateTime?             @map("fecha_recepcion")
  observaciones        String?               @db.Text
  metadata             Json?                 @db.JsonB
  creadoPorUsuarioId   String                @map("creado_por_usuario_id") @db.Uuid
  creadoEn             DateTime              @default(now()) @map("creado_en")
  actualizadoEn        DateTime              @updatedAt @map("actualizado_en")

  pedido          Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  pedidoItem      PedidoItem?      @relation(fields: [pedidoItemId], references: [id], onDelete: SetNull)
  ordenProduccion OrdenProduccion? @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden        Suborden?        @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  recibidoPor     Usuario?         @relation("MaterialClienteRecibidoPor", fields: [recibidoPorUsuarioId], references: [id], onDelete: SetNull)
  creadoPor       Usuario          @relation("MaterialClienteCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([pedidoItemId])
  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([estado])
  @@map("material_cliente")
}

// ------------------------------------------------------------
// ValidacionPedido — proceso formal de validación antes de activar el pedido para producción
// El coordinador revisa que el pedido esté completo, correcto y con documentos suficientes.
// Un pedido puede pasar por múltiples rondas de validación si se rechaza y corrige.
// ------------------------------------------------------------
model ValidacionPedido {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId             String                 @map("pedido_id") @db.Uuid
  validadoPorUsuarioId String?                @map("validado_por_usuario_id") @db.Uuid
  estadoValidacion     EstadoValidacionPedido @default(PENDIENTE) @map("estado_validacion")
  observaciones        String?                @db.Text
  metadata             Json?                  @db.JsonB
  creadoEn             DateTime               @default(now()) @map("creado_en")
  actualizadoEn        DateTime               @updatedAt @map("actualizado_en")

  pedido      Pedido                    @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  validadoPor Usuario?                  @relation(fields: [validadoPorUsuarioId], references: [id], onDelete: SetNull)
  detalles    ValidacionPedidoDetalle[]

  @@index([pedidoId])
  @@index([estadoValidacion])
  @@map("validaciones_pedido")
}

// ------------------------------------------------------------
// ValidacionPedidoDetalle — ítem individual verificado dentro de una validación de pedido
// Registra cada aspecto chequeado y su resultado binario de aprobación.
// ------------------------------------------------------------
model ValidacionPedidoDetalle {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  validacionPedidoId String   @map("validacion_pedido_id") @db.Uuid
  tipoVerificacion   String   @map("tipo_verificacion") @db.VarChar(150)
  aprobado           Boolean
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")

  validacion ValidacionPedido @relation(fields: [validacionPedidoId], references: [id], onDelete: Cascade)

  @@index([validacionPedidoId])
  @@map("validacion_pedido_detalles")
}

// ------------------------------------------------------------
// Entrega — evento de entrega parcial o total de ítems al cliente
// La entrega parcial planeada ocurre cuando el vendedor indica que el cliente retirará
// parte del pedido antes de que se complete todo el proceso.
// Un despacho incompleto (distinto de entrega parcial planeada) puede también generar PQRS.
// contactoClienteId: persona del cliente que recibe físicamente la entrega.
// recibeNombre: nombre libre del receptor si no está registrado como contacto.
// ------------------------------------------------------------
model Entrega {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId              String   @map("pedido_id") @db.Uuid
  contactoClienteId     String?  @map("contacto_cliente_id") @db.Uuid
  entregadoPorUsuarioId String   @map("entregado_por_usuario_id") @db.Uuid
  recibeNombre          String?  @map("recibe_nombre") @db.VarChar(200)
  observaciones         String?  @db.Text
  metadata              Json?    @db.JsonB
  creadoEn              DateTime @default(now()) @map("creado_en")

  pedido          Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  contactoCliente ContactoCliente? @relation(fields: [contactoClienteId], references: [id], onDelete: SetNull)
  entregadoPor    Usuario          @relation(fields: [entregadoPorUsuarioId], references: [id], onDelete: Restrict)
  items           EntregaItem[]

  @@index([pedidoId])
  @@index([contactoClienteId])
  @@map("entregas")
}

// ------------------------------------------------------------
// EntregaItem — detalle de cada ítem incluido en un evento de entrega
// cantidadPendientePosterior: CAMPO CALCULADO INMUTABLE — cantidad que quedó pendiente
// DESPUÉS de esta entrega. Fórmula: cantidadPendiente_antes − cantidadEntregada.
// No se recalcula retroactivamente; es el snapshot inmutable en el momento de la entrega.
// ------------------------------------------------------------
model EntregaItem {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entregaId                  String   @map("entrega_id") @db.Uuid
  pedidoItemId               String   @map("pedido_item_id") @db.Uuid
  cantidadEntregada          Decimal  @map("cantidad_entregada") @db.Decimal(14, 4)
  // CAMPO CALCULADO INMUTABLE: snapshot de cantidad pendiente después de esta entrega
  cantidadPendientePosterior Decimal  @map("cantidad_pendiente_posterior") @db.Decimal(14, 4)
  observaciones              String?  @db.Text
  creadoEn                   DateTime @default(now()) @map("creado_en")

  entrega    Entrega    @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: Restrict)

  @@index([entregaId])
  @@index([pedidoItemId])
  @@map("entrega_items")
}

// ------------------------------------------------------------
// HistorialEstadoPedido — registro inmutable de cada cambio de estado de un pedido
// IMPORTANTE: debe escribirse junto con auditoria_general dentro de la misma transacción
// para garantizar consistencia entre el historial operativo y el registro de auditoría.
// estadoAnteriorId: nullable en la transición inicial (pedido recién creado, sin estado previo).
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model HistorialEstadoPedido {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId           String   @map("pedido_id") @db.Uuid
  estadoAnteriorId   String?  @map("estado_anterior_id") @db.Uuid
  estadoNuevoId      String   @map("estado_nuevo_id") @db.Uuid
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")

  pedido         Pedido         @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  estadoAnterior EstadoSistema? @relation("EstadoAnteriorPedido", fields: [estadoAnteriorId], references: [id], onDelete: SetNull)
  estadoNuevo    EstadoSistema  @relation("EstadoNuevoPedido", fields: [estadoNuevoId], references: [id], onDelete: Restrict)
  creadoPor      Usuario?       @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([estadoNuevoId])
  @@index([creadoEn])
  @@map("historial_estados_pedido")
}

// ------------------------------------------------------------
// AsignacionPedido — historial de asignaciones del pedido a un vendedor
// Al reasignar: NO se sobrescribe el registro anterior.
// Se cierra la asignación activa con fechaFinAsignacion y se crea un nuevo registro.
// La asignación actualmente activa es la que tiene fechaFinAsignacion IS NULL.
// Esto permite auditar todos los cambios de vendedor con motivo y autorizador.
// ------------------------------------------------------------
model AsignacionPedido {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId              String    @map("pedido_id") @db.Uuid
  vendedorId            String    @map("vendedor_id") @db.Uuid
  asignadoPorUsuarioId  String    @map("asignado_por_usuario_id") @db.Uuid
  fechaInicioAsignacion DateTime  @map("fecha_inicio_asignacion")
  fechaFinAsignacion    DateTime? @map("fecha_fin_asignacion")
  motivo                String?   @db.VarChar(500)
  observaciones         String?   @db.Text
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  pedido      Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  vendedor    Usuario @relation("AsignacionVendedor", fields: [vendedorId], references: [id], onDelete: Restrict)
  asignadoPor Usuario @relation("AsignacionRealizadaPor", fields: [asignadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([vendedorId])
  @@index([pedidoId, fechaFinAsignacion])
  @@map("asignaciones_pedido")
}

// ------------------------------------------------------------
// BloqueoPedido — registro de bloqueos activos o históricos de un pedido
// Un pedido bloqueado no puede avanzar en producción ni despacho sin resolución explícita.
// FACTURA_ANULADA: ContaPyme anuló la factura; bloqueo obligatorio hasta revisión del admin.
// bloqueadoPorUsuarioId: nullable si el bloqueo fue generado automáticamente por el sistema.
// fechaDesbloqueo: se llena cuando el administrador resuelve el bloqueo; el registro no se elimina.
// ------------------------------------------------------------
model BloqueoPedido {
  id                       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                 String      @map("pedido_id") @db.Uuid
  tipoBloqueo              TipoBloqueo @map("tipo_bloqueo")
  motivoBloqueo            String      @map("motivo_bloqueo") @db.VarChar(500)
  bloqueadoPorUsuarioId    String?     @map("bloqueado_por_usuario_id") @db.Uuid
  desbloqueadoPorUsuarioId String?     @map("desbloqueado_por_usuario_id") @db.Uuid
  fechaBloqueo             DateTime    @map("fecha_bloqueo")
  fechaDesbloqueo          DateTime?   @map("fecha_desbloqueo")
  observaciones            String?     @db.Text
  metadata                 Json?       @db.JsonB
  creadoEn                 DateTime    @default(now()) @map("creado_en")
  actualizadoEn            DateTime    @updatedAt @map("actualizado_en")

  pedido          Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  bloqueadoPor    Usuario? @relation("BloqueoPedidoCreadoPor", fields: [bloqueadoPorUsuarioId], references: [id], onDelete: SetNull)
  desbloqueadoPor Usuario? @relation("BloqueoPedidoDesbloqueadoPor", fields: [desbloqueadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([tipoBloqueo])
  @@index([fechaDesbloqueo])
  @@map("bloqueos_pedido")
}

// ------------------------------------------------------------
// PedidoSede — historial de traslados o cambios de sede de un pedido
// Registra cada movimiento con trazabilidad completa: solicitante, autorizador, motivo.
// No tiene actualizadoEn: cada evento de movimiento es inmutable.
// Compras debe ser notificado para validar disponibilidad de materiales en la nueva sede.
// ------------------------------------------------------------
model PedidoSede {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId               String             @map("pedido_id") @db.Uuid
  sedeOrigenId           String             @map("sede_origen_id") @db.Uuid
  sedeDestinoId          String             @map("sede_destino_id") @db.Uuid
  tipoMovimientoSede     TipoMovimientoSede @map("tipo_movimiento_sede")
  solicitadoPorUsuarioId String             @map("solicitado_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?            @map("autorizado_por_usuario_id") @db.Uuid
  fechaMovimiento        DateTime           @map("fecha_movimiento")
  observaciones          String             @db.Text
  metadata               Json?              @db.JsonB
  creadoEn               DateTime           @default(now()) @map("creado_en")

  pedido        Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sedeOrigen    Sede     @relation("PedidoSedeOrigen", fields: [sedeOrigenId], references: [id], onDelete: Restrict)
  sedeDestino   Sede     @relation("PedidoSedeDestino", fields: [sedeDestinoId], references: [id], onDelete: Restrict)
  solicitadoPor Usuario  @relation("PedidoSedeSolicitadaPor", fields: [solicitadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor Usuario? @relation("PedidoSedeAutorizadaPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([pedidoId])
  @@index([sedeOrigenId])
  @@index([sedeDestinoId])
  @@map("pedido_sedes")
}

// ------------------------------------------------------------
// FacturaPedido — relación explícita entre facturas y pedidos (pendiente del Bloque 3)
// esPrincipal: identifica la factura principal operativa del pedido. Un pedido debe tener
// una sola factura PRINCIPAL; las adicionales amplían o complementan el alcance.
// La restricción de unicidad de esPrincipal=true por pedido se valida en backend.
// tipoRelacion REEMPLAZO: nueva factura sustituye operativamente a la anterior anulada.
// tipoRelacion DEVOLUCION: nota crédito vinculada al pedido por reclamo o ajuste.
// ------------------------------------------------------------
model FacturaPedido {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facturaId               String                    @map("factura_id") @db.Uuid
  pedidoId                String                    @map("pedido_id") @db.Uuid
  tipoRelacion            TipoRelacionFacturaPedido @map("tipo_relacion")
  esPrincipal             Boolean                   @default(false) @map("es_principal")
  fechaRelacion           DateTime                  @map("fecha_relacion")
  relacionadoPorUsuarioId String                    @map("relacionado_por_usuario_id") @db.Uuid
  observaciones           String?                   @db.Text
  creadoEn                DateTime                  @default(now()) @map("creado_en")
  actualizadoEn           DateTime                  @updatedAt @map("actualizado_en")

  factura        Factura @relation(fields: [facturaId], references: [id], onDelete: Restrict)
  pedido         Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  relacionadoPor Usuario @relation(fields: [relacionadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@unique([facturaId, pedidoId, tipoRelacion])
  @@index([facturaId])
  @@index([pedidoId])
  @@index([esPrincipal])
  @@map("factura_pedido")
}

// =============================================================
// BLOQUE 5 — Producción y Subórdenes
// =============================================================

// ------------------------------------------------------------
// Enum: tipo de evento registrado durante el proceso productivo
// INICIO_ETAPA / FIN_ETAPA: marca el inicio y fin de una etapa de producción.
// NOVEDAD: situación inesperada que interrumpe o altera el proceso.
// REPROCESO: una pieza debe reprocessarse por daño, error o rechazo.
// CAMBIO_PRIORIDAD: se modifica el orden de prioridad de la orden o suborden.
// ASIGNACION_MAQUINA: se asigna o cambia la máquina principal de la orden.
// AUTORIZACION: un responsable aprueba una acción crítica.
// PAUSA: la producción se detiene temporalmente de forma controlada.
// ------------------------------------------------------------
enum TipoEventoOperativo {
  INICIO_ETAPA
  FIN_ETAPA
  NOVEDAD
  REPROCESO
  CAMBIO_PRIORIDAD
  ASIGNACION_MAQUINA
  AUTORIZACION
  PAUSA
}

// ------------------------------------------------------------
// EtapaProduccion — catálogo de etapas del proceso productivo
// Ejemplos: CORTE, ENCHAPE, PERFORACION, ARMADO, CONTROL_CALIDAD
// orden define la secuencia típica de ejecución dentro del flujo productivo.
// ------------------------------------------------------------
model EtapaProduccion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @unique @db.VarChar(100)
  codigo        String   @unique @db.VarChar(50)
  descripcion   String?  @db.Text
  orden         Int
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  ordenEtapas OrdenEtapa[]

  @@index([orden])
  @@map("etapas_produccion")
}

// ------------------------------------------------------------
// OrdenProduccion — unidad de trabajo productivo para un pedido
// estadoOrdenId: FK a estados_sistema (no enum libre); permite configuración
// dinámica de estados sin migraciones adicionales.
// sedeProduccionId: sede donde se ejecuta la producción física.
// sedeDespachoId: sede desde donde saldrá el producto terminado (nullable si no definida aún).
// sedeActualId: sede donde se encuentra físicamente la orden en este momento.
// maquinaPrincipalId: máquina CNC principal asignada (nullable si aún no se asigna).
// generadaAutomaticamente: true si fue propuesta por el sistema al cargar el pedido.
// ordenPrioridad: entero para ordenar la cola de producción (menor = mayor urgencia).
// IMPORTANTE: cambios de estado deben escribirse junto con historial_estados_orden
// y auditoria_general dentro de la misma transacción para garantizar atomicidad.
// ------------------------------------------------------------
model OrdenProduccion {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                String    @map("pedido_id") @db.Uuid
  sedeProduccionId        String    @map("sede_produccion_id") @db.Uuid
  sedeDespachoId          String?   @map("sede_despacho_id") @db.Uuid
  sedeActualId            String    @map("sede_actual_id") @db.Uuid
  maquinaPrincipalId      String?   @map("maquina_principal_id") @db.Uuid
  estadoOrdenId           String    @map("estado_orden_id") @db.Uuid
  creadoPorUsuarioId      String    @map("creado_por_usuario_id") @db.Uuid
  generadaAutomaticamente Boolean   @default(false) @map("generada_automaticamente")
  ordenPrioridad          Int       @default(0) @map("orden_prioridad")
  fechaInicioPlaneada     DateTime? @map("fecha_inicio_planeada")
  fechaFinPlaneada        DateTime? @map("fecha_fin_planeada")
  fechaInicioReal         DateTime? @map("fecha_inicio_real")
  fechaFinReal            DateTime? @map("fecha_fin_real")
  observaciones           String?   @db.Text
  metadata                Json?     @db.JsonB
  creadoEn                DateTime  @default(now()) @map("creado_en")
  actualizadoEn           DateTime  @updatedAt @map("actualizado_en")

  pedido                 Pedido                  @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sedeProduccion         Sede                    @relation("OrdenSedeProduccion", fields: [sedeProduccionId], references: [id], onDelete: Restrict)
  sedeDespacho           Sede?                   @relation("OrdenSedeDespacho", fields: [sedeDespachoId], references: [id], onDelete: SetNull)
  sedeActual             Sede                    @relation("OrdenSedeActual", fields: [sedeActualId], references: [id], onDelete: Restrict)
  maquinaPrincipal       Maquina?                @relation("OrdenMaquinaPrincipal", fields: [maquinaPrincipalId], references: [id], onDelete: SetNull)
  estadoOrden            EstadoSistema           @relation("OrdenEstado", fields: [estadoOrdenId], references: [id], onDelete: Restrict)
  creadoPor              Usuario                 @relation("OrdenProduccionCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  subordenes             Suborden[]
  etapas                 OrdenEtapa[]            @relation("OrdenEtapaOrden")
  eventos                EventoOperativo[]
  novedades              NovedadOperativa[]
  materialesCliente      MaterialCliente[]
  historialEstados       HistorialEstadoOrden[]
  calculosPerdidas       CalculoPerdidas[]
  // Bloque 6 — Abastecimiento
  requerimientosMaterial RequerimientoMaterial[]
  movimientosMaterial    MovimientoMaterial[]
  materialesReservados   MaterialReservado[]

  @@index([pedidoId])
  @@index([sedeProduccionId])
  @@index([sedeActualId])
  @@index([estadoOrdenId])
  @@index([ordenPrioridad])
  @@map("ordenes_produccion")
}

// ------------------------------------------------------------
// Suborden — unidad de trabajo específica dentro de una orden o pedido
// Representa procesos adicionales: perforaciones, reengrueses, entamborados,
// instalación de perfilería, armado de puertas, servicios especiales de taller.
// pedidoId: siempre requerido; la suborden pertenece a un pedido.
// ordenProduccionId: opcional; la suborden puede ser hija de una orden específica
// o mantenerse al nivel del pedido para servicios generales no ligados a una orden.
// generadaAutomaticamente: true si fue sugerida por el sistema al analizar el pedido.
// IMPORTANTE: cambios de estado deben escribirse junto con historial_estados_suborden
// y auditoria_general dentro de la misma transacción para garantizar atomicidad.
// ------------------------------------------------------------
model Suborden {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                String    @map("pedido_id") @db.Uuid
  ordenProduccionId       String?   @map("orden_produccion_id") @db.Uuid
  sedeProduccionId        String    @map("sede_produccion_id") @db.Uuid
  sedeDespachoId          String?   @map("sede_despacho_id") @db.Uuid
  estadoSubordenId        String    @map("estado_suborden_id") @db.Uuid
  creadoPorUsuarioId      String    @map("creado_por_usuario_id") @db.Uuid
  generadaAutomaticamente Boolean   @default(false) @map("generada_automaticamente")
  tipoSuborden            String    @map("tipo_suborden") @db.VarChar(150)
  ordenPrioridad          Int       @default(0) @map("orden_prioridad")
  fechaInicioPlaneada     DateTime? @map("fecha_inicio_planeada")
  fechaFinPlaneada        DateTime? @map("fecha_fin_planeada")
  fechaInicioReal         DateTime? @map("fecha_inicio_real")
  fechaFinReal            DateTime? @map("fecha_fin_real")
  observaciones           String?   @db.Text
  metadata                Json?     @db.JsonB
  creadoEn                DateTime  @default(now()) @map("creado_en")
  actualizadoEn           DateTime  @updatedAt @map("actualizado_en")

  pedido                 Pedido                    @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  ordenProduccion        OrdenProduccion?          @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  sedeProduccion         Sede                      @relation("SubordenSedeProduccion", fields: [sedeProduccionId], references: [id], onDelete: Restrict)
  sedeDespacho           Sede?                     @relation("SubordenSedeDespacho", fields: [sedeDespachoId], references: [id], onDelete: SetNull)
  estadoSuborden         EstadoSistema             @relation("SubordenEstado", fields: [estadoSubordenId], references: [id], onDelete: Restrict)
  creadoPor              Usuario                   @relation("SubordenCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  etapas                 OrdenEtapa[]              @relation("OrdenEtapaSuborden")
  eventos                EventoOperativo[]
  novedades              NovedadOperativa[]
  materialesCliente      MaterialCliente[]
  historialEstados       HistorialEstadoSuborden[]
  // Bloque 6 — Abastecimiento
  requerimientosMaterial RequerimientoMaterial[]
  movimientosMaterial    MovimientoMaterial[]
  materialesReservados   MaterialReservado[]

  @@index([pedidoId])
  @@index([ordenProduccionId])
  @@index([sedeProduccionId])
  @@index([estadoSubordenId])
  @@index([ordenPrioridad])
  @@map("subordenes")
}

// ------------------------------------------------------------
// OrdenEtapa — etapa de producción asignada a una orden o suborden
// RESTRICCIÓN XOR: exactamente uno de (ordenProduccionId, subordenId) debe ser NOT NULL.
// Prisma 5 no puede expresar CHECK constraints; aplicar en SQL directamente:
//   ALTER TABLE orden_etapas
//   ADD CONSTRAINT chk_orden_etapa_xor
//   CHECK (
//     (orden_produccion_id IS NOT NULL AND suborden_id IS NULL) OR
//     (orden_produccion_id IS NULL     AND suborden_id IS NOT NULL)
//   );
// Además, validar en backend (service layer) antes de persistir.
// estadoEtapaId: FK a estados_sistema módulo 'etapa_produccion'.
// ------------------------------------------------------------
model OrdenEtapa {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenProduccionId String?   @map("orden_produccion_id") @db.Uuid
  subordenId        String?   @map("suborden_id") @db.Uuid
  etapaProduccionId String    @map("etapa_produccion_id") @db.Uuid
  estadoEtapaId     String    @map("estado_etapa_id") @db.Uuid
  fechaInicio       DateTime? @map("fecha_inicio")
  fechaFin          DateTime? @map("fecha_fin")
  observaciones     String?   @db.Text
  creadoEn          DateTime  @default(now()) @map("creado_en")
  actualizadoEn     DateTime  @updatedAt @map("actualizado_en")

  ordenProduccion OrdenProduccion?  @relation("OrdenEtapaOrden", fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden        Suborden?         @relation("OrdenEtapaSuborden", fields: [subordenId], references: [id], onDelete: SetNull)
  etapaProduccion EtapaProduccion   @relation(fields: [etapaProduccionId], references: [id], onDelete: Restrict)
  estadoEtapa     EstadoSistema     @relation("OrdenEtapaEstado", fields: [estadoEtapaId], references: [id], onDelete: Restrict)
  asignaciones    OrdenAsignacion[]

  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([etapaProduccionId])
  @@index([estadoEtapaId])
  @@map("orden_etapas")
}

// ------------------------------------------------------------
// OrdenAsignacion — asignación de operario y máquina a una orden de producción
// Al reasignar: NO se sobrescribe el registro anterior.
// Se cierra la asignación activa con fechaFinAsignacion y se crea un nuevo registro.
// La asignación activa es la que tiene fechaFinAsignacion IS NULL.
// Permite auditar todos los cambios de operario/máquina durante el ciclo de vida de la orden.
// ------------------------------------------------------------
model OrdenAsignacion {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenEtapaId          String    @map("orden_etapa_id") @db.Uuid
  maquinaId             String?   @map("maquina_id") @db.Uuid
  operadorId            String    @map("operador_id") @db.Uuid
  asignadoPorUsuarioId  String    @map("asignado_por_usuario_id") @db.Uuid
  fechaInicioAsignacion DateTime  @map("fecha_inicio_asignacion")
  fechaFinAsignacion    DateTime? @map("fecha_fin_asignacion")
  motivo                String?   @db.VarChar(500)
  observaciones         String?   @db.Text
  creadoEn              DateTime  @default(now()) @map("creado_en")
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en")

  ordenEtapa  OrdenEtapa @relation(fields: [ordenEtapaId], references: [id], onDelete: Restrict)
  maquina     Maquina?   @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  operador    Usuario    @relation("OrdenAsignacionOperador", fields: [operadorId], references: [id], onDelete: Restrict)
  asignadoPor Usuario    @relation("OrdenAsignacionRealizadaPor", fields: [asignadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([ordenEtapaId])
  @@index([operadorId])
  @@index([ordenEtapaId, fechaFinAsignacion])
  @@map("orden_asignaciones")
}

// ------------------------------------------------------------
// EventoOperativo — registro cronológico de eventos durante la producción
// tipoEvento: controlado por enum TipoEventoOperativo para garantizar integridad.
// Solo uno de (ordenProduccionId, subordenId) debe estar activo por evento;
// validar en backend antes de persistir.
// No tiene actualizadoEn: el registro de evento es inmutable.
// ------------------------------------------------------------
model EventoOperativo {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenProduccionId String?             @map("orden_produccion_id") @db.Uuid
  subordenId        String?             @map("suborden_id") @db.Uuid
  tipoEvento        TipoEventoOperativo @map("tipo_evento")
  descripcion       String              @db.Text
  registradoPorId   String              @map("registrado_por_id") @db.Uuid
  fechaEvento       DateTime            @map("fecha_evento")
  metadata          Json?               @db.JsonB
  creadoEn          DateTime            @default(now()) @map("creado_en")

  ordenProduccion OrdenProduccion? @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden        Suborden?        @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  registradoPor   Usuario          @relation(fields: [registradoPorId], references: [id], onDelete: Restrict)

  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([tipoEvento])
  @@index([fechaEvento])
  @@map("eventos_operativos")
}

// ------------------------------------------------------------
// NovedadOperativa — registro de situaciones inesperadas que afectan la producción
// Puede ser: daño de material, falla de máquina, error operativo, material faltante, etc.
// reprocesoId: se llena cuando la novedad genera un reproceso; nullable hasta que se cree.
// Relación circular con Reproceso resuelta con dos relaciones nombradas distintas:
//   "NovedadTieneReproceso": FK en esta tabla (reprocesoId → reprocesos.id)
//   "ReprocesoOrigenNovedad": FK en reprocesos (novedadOperativaId → novedades_operativas.id)
// cerrada + fechaCierre: se llenan cuando la novedad queda resuelta.
// ------------------------------------------------------------
model NovedadOperativa {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoNovedadId     String    @map("tipo_novedad_id") @db.Uuid
  ordenProduccionId String?   @map("orden_produccion_id") @db.Uuid
  subordenId        String?   @map("suborden_id") @db.Uuid
  // @unique garantiza 1:1 con Reproceso; la novedad tiene como máximo un reproceso resultado
  reprocesoId       String?   @unique @map("reproceso_id") @db.Uuid
  reportadoPorId    String    @map("reportado_por_id") @db.Uuid
  descripcion       String    @db.Text
  solucionAplicada  String?   @map("solucion_aplicada") @db.Text
  fechaNovedad      DateTime  @map("fecha_novedad")
  cerrada           Boolean   @default(false)
  fechaCierre       DateTime? @map("fecha_cierre")
  observaciones     String?   @db.Text
  metadata          Json?     @db.JsonB
  creadoEn          DateTime  @default(now()) @map("creado_en")
  actualizadoEn     DateTime  @updatedAt @map("actualizado_en")

  tipoNovedad           TipoNovedad      @relation(fields: [tipoNovedadId], references: [id], onDelete: Restrict)
  ordenProduccion       OrdenProduccion? @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden              Suborden?        @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  // FK hacia el reproceso que resultó de esta novedad (circular, resuelta con nombre)
  novedadTieneReproceso Reproceso?       @relation("NovedadTieneReproceso", fields: [reprocesoId], references: [id], onDelete: SetNull)
  reportadoPor          Usuario          @relation(fields: [reportadoPorId], references: [id], onDelete: Restrict)
  // Back-ref: reprocesos que señalan esta novedad como su origen
  reprocesosGenerados   Reproceso[]      @relation("ReprocesoOrigenNovedad")

  @@index([tipoNovedadId])
  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([cerrada])
  @@map("novedades_operativas")
}

// ------------------------------------------------------------
// Reproceso — acción correctiva derivada de una novedad operativa
// novedadOperativaId: siempre requerido; todo reproceso nace de una novedad.
// pedidoOrigenId: pedido de cuyo inventario se tomó material para el reproceso.
// itemOrigenId: ítem que fue dañado o que causó la necesidad del reproceso.
// itemId: ítem utilizado como reposición o en la solución del reproceso.
// alertaReposicionPendiente: true cuando se usó material de otro pedido y falta reponer.
// Relación circular con NovedadOperativa resuelta con dos relaciones nombradas distintas:
//   "ReprocesoOrigenNovedad": FK en esta tabla (novedadOperativaId → novedades_operativas.id)
//   "NovedadTieneReproceso": FK en novedades_operativas (reprocesoId → reprocesos.id)
// IMPORTANTE: debe escribirse junto con novedad_operativa y auditoria_general en transacción.
// ------------------------------------------------------------
model Reproceso {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  novedadOperativaId        String   @map("novedad_operativa_id") @db.Uuid
  pedidoOrigenId            String?  @map("pedido_origen_id") @db.Uuid
  itemOrigenId              String?  @map("item_origen_id") @db.Uuid
  itemId                    String?  @map("item_id") @db.Uuid
  cantidadUsada             Decimal? @map("cantidad_usada") @db.Decimal(14, 4)
  motivoReproceso           String   @map("motivo_reproceso") @db.VarChar(500)
  solucionAplicada          String?  @map("solucion_aplicada") @db.Text
  autorizadoPorUsuarioId    String   @map("autorizado_por_usuario_id") @db.Uuid
  creadoPorUsuarioId        String   @map("creado_por_usuario_id") @db.Uuid
  fechaReproceso            DateTime @map("fecha_reproceso")
  costoEstimado             Decimal? @map("costo_estimado") @db.Decimal(14, 4)
  alertaReposicionPendiente Boolean  @default(false) @map("alerta_reposicion_pendiente")
  observaciones             String?  @db.Text
  metadata                  Json?    @db.JsonB
  creadoEn                  DateTime @default(now()) @map("creado_en")
  actualizadoEn             DateTime @updatedAt @map("actualizado_en")

  // Novedad que originó este reproceso (relación principal, siempre requerida)
  novedadOperativa    NovedadOperativa  @relation("ReprocesoOrigenNovedad", fields: [novedadOperativaId], references: [id], onDelete: Restrict)
  // Back-ref circular: la novedad que apunta a este reproceso como resultado
  novedadConReproceso NovedadOperativa? @relation("NovedadTieneReproceso")
  pedidoOrigen        Pedido?           @relation("ReprocesoOrigenPedido", fields: [pedidoOrigenId], references: [id], onDelete: SetNull)
  itemOrigen          Item?             @relation("ReprocesoItemOrigen", fields: [itemOrigenId], references: [id], onDelete: SetNull)
  item                Item?             @relation("ReprocesoItemUtilizado", fields: [itemId], references: [id], onDelete: SetNull)
  autorizadoPor       Usuario           @relation("ReprocesoAutorizadoPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: Restrict)
  creadoPor           Usuario           @relation("ReprocesoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([novedadOperativaId])
  @@index([pedidoOrigenId])
  @@index([autorizadoPorUsuarioId])
  @@map("reprocesos")
}

// ------------------------------------------------------------
// HistorialEstadoOrden — registro inmutable de cada cambio de estado de una orden de producción
// IMPORTANTE: debe escribirse junto con auditoria_general dentro de la misma transacción.
// estadoAnteriorId: nullable en la transición inicial (orden recién creada, sin estado previo).
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model HistorialEstadoOrden {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenProduccionId  String   @map("orden_produccion_id") @db.Uuid
  estadoAnteriorId   String?  @map("estado_anterior_id") @db.Uuid
  estadoNuevoId      String   @map("estado_nuevo_id") @db.Uuid
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")

  ordenProduccion OrdenProduccion @relation(fields: [ordenProduccionId], references: [id], onDelete: Restrict)
  estadoAnterior  EstadoSistema?  @relation("EstadoAnteriorOrden", fields: [estadoAnteriorId], references: [id], onDelete: SetNull)
  estadoNuevo     EstadoSistema   @relation("EstadoNuevoOrden", fields: [estadoNuevoId], references: [id], onDelete: Restrict)
  creadoPor       Usuario?        @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([ordenProduccionId])
  @@index([estadoNuevoId])
  @@index([creadoEn])
  @@map("historial_estados_orden")
}

// ------------------------------------------------------------
// HistorialEstadoSuborden — registro inmutable de cada cambio de estado de una suborden
// IMPORTANTE: debe escribirse junto con auditoria_general dentro de la misma transacción.
// estadoAnteriorId: nullable en la transición inicial (suborden recién creada).
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model HistorialEstadoSuborden {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subordenId         String   @map("suborden_id") @db.Uuid
  estadoAnteriorId   String?  @map("estado_anterior_id") @db.Uuid
  estadoNuevoId      String   @map("estado_nuevo_id") @db.Uuid
  creadoPorUsuarioId String?  @map("creado_por_usuario_id") @db.Uuid
  observaciones      String?  @db.Text
  metadata           Json?    @db.JsonB
  creadoEn           DateTime @default(now()) @map("creado_en")

  suborden       Suborden       @relation(fields: [subordenId], references: [id], onDelete: Restrict)
  estadoAnterior EstadoSistema? @relation("EstadoAnteriorSuborden", fields: [estadoAnteriorId], references: [id], onDelete: SetNull)
  estadoNuevo    EstadoSistema  @relation("EstadoNuevoSuborden", fields: [estadoNuevoId], references: [id], onDelete: Restrict)
  creadoPor      Usuario?       @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([subordenId])
  @@index([estadoNuevoId])
  @@index([creadoEn])
  @@map("historial_estados_suborden")
}

// ------------------------------------------------------------
// CalculoPerdidas — registro de pérdidas al cancelar una orden que ya inició producción
// Solo se genera cuando una orden cancela después de haber iniciado producción.
// Si la orden no inició producción, la cancelación es directa (sin pérdidas a calcular).
// materialConsumido: JSONB con detalle de materiales ya procesados (ítem, cantidad, costo).
// piezasProducidas / piezasDaniadas: conteo de piezas en estado diferente al ideal.
// tiempoInvertidoMinutos: tiempo operativo consumido antes de la cancelación.
// costoEstimado: impacto económico estimado; puede ser cero si no hay consumo de inventario.
// No tiene actualizadoEn: el cálculo es inmutable una vez registrado y autorizado.
// ------------------------------------------------------------
model CalculoPerdidas {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ordenProduccionId      String   @map("orden_produccion_id") @db.Uuid
  materialConsumido      Json     @map("material_consumido") @db.JsonB
  piezasProducidas       Int?     @map("piezas_producidas")
  piezasDaniadas         Int?     @map("piezas_daniadas")
  tiempoInvertidoMinutos Int?     @map("tiempo_invertido_minutos")
  costoEstimado          Decimal? @map("costo_estimado") @db.Decimal(14, 4)
  motivoCancelacion      String   @map("motivo_cancelacion") @db.VarChar(500)
  autorizadoPorUsuarioId String   @map("autorizado_por_usuario_id") @db.Uuid
  observaciones          String?  @db.Text
  creadoEn               DateTime @default(now()) @map("creado_en")

  ordenProduccion OrdenProduccion @relation(fields: [ordenProduccionId], references: [id], onDelete: Restrict)
  autorizadoPor   Usuario         @relation(fields: [autorizadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([ordenProduccionId])
  @@map("calculo_perdidas")
}

// =============================================================
// BLOQUE 6 — Abastecimiento, Compras e Inventario Operativo
// =============================================================

// ------------------------------------------------------------
// Enum: tipo operativo de requerimiento de material
// Determina el origen y la acción que genera el requerimiento.
// PRODUCCION: originado por una orden o suborden de producción.
// COMPRA: se requiere una compra directa al proveedor.
// TRASLADO: el material debe venir de otra sede mediante traslado.
// RESERVA: pre-reserva de material disponible antes de cualquier acción.
// GENERAL: requerimiento administrativo no asociado a producción.
// ------------------------------------------------------------
enum TipoRequerimiento {
  PRODUCCION
  COMPRA
  TRASLADO
  RESERVA
  GENERAL
}

// ------------------------------------------------------------
// Enum: tipo de movimiento de material sobre el inventario operativo
// Determina la dirección del impacto en cantidadDisponible:
//   ENTRADA_*: incrementan cantidadDisponible
//   SALIDA_*: decrementan cantidadDisponible
//   RESERVA / LIBERACION_RESERVA: afectan cantidadReservada sin cambiar cantidadDisponible
//   SALIDA_PRODUCCION: también puede reducir cantidadEnProduccion según el flujo
// DEVOLUCION_PROVEEDOR: salida hacia el proveedor por rechazo o devolución.
// ------------------------------------------------------------
enum TipoMovimientoMaterial {
  ENTRADA_COMPRA
  ENTRADA_TRASLADO
  ENTRADA_AJUSTE
  SALIDA_PRODUCCION
  SALIDA_TRASLADO
  SALIDA_AJUSTE
  RESERVA
  LIBERACION_RESERVA
  DEVOLUCION_PROVEEDOR
}

// ------------------------------------------------------------
// Enum: tipo de alerta operativa de abastecimiento
// STOCK_MINIMO: cantidad disponible cayó por debajo del umbral mínimo definido.
// STOCK_CRITICO: stock en cero o negativo; producción en riesgo inmediato.
// RETRASO_ENTREGA: el proveedor no entregó en la fecha estimada.
// SIN_PROVEEDOR: se requiere el material pero no hay proveedor registrado.
// COMPRA_PENDIENTE: existe requerimiento aprobado sin solicitud de compra creada.
// RESERVA_INSUFICIENTE: la cantidad reservada supera la disponible en inventario.
// ------------------------------------------------------------
enum TipoAlertaAbastecimiento {
  STOCK_MINIMO
  STOCK_CRITICO
  RETRASO_ENTREGA
  SIN_PROVEEDOR
  COMPRA_PENDIENTE
  RESERVA_INSUFICIENTE
}

// ------------------------------------------------------------
// Enum: estado de una reserva de material
// ACTIVA: material reservado; contabiliza en cantidadReservada de inventario_operativo.
// LIBERADA: reserva cancelada explícitamente antes de ser consumida.
// CONSUMIDA: el material fue efectivamente usado (movimiento SALIDA_PRODUCCION emitido).
// CANCELADA: la orden o pedido que generó la reserva fue cancelado.
// ------------------------------------------------------------
enum EstadoReservaMaterial {
  ACTIVA
  LIBERADA
  CONSUMIDA
  CANCELADA
}

// ------------------------------------------------------------
// RequerimientoMaterial — solicitud interna de material generada por producción u operaciones
// Puede originarse desde una orden, suborden, pedido o manualmente.
// estadoRequerimientoId: FK a estados_sistema (módulo 'requerimiento_material').
//   Estados sugeridos: PENDIENTE, APROBADO, EN_GESTION, ATENDIDO, CANCELADO.
// cantidadAtendida: total ya provisto (suma de movimientos de entrada asociados).
// IMPORTANTE: cambios de estado deben escribirse junto con auditoria_general en transacción.
// ------------------------------------------------------------
model RequerimientoMaterial {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId                String            @map("item_id") @db.Uuid
  sedeId                String            @map("sede_id") @db.Uuid
  ordenProduccionId     String?           @map("orden_produccion_id") @db.Uuid
  subordenId            String?           @map("suborden_id") @db.Uuid
  pedidoId              String?           @map("pedido_id") @db.Uuid
  tipoRequerimiento     TipoRequerimiento @map("tipo_requerimiento")
  estadoRequerimientoId String            @map("estado_requerimiento_id") @db.Uuid
  fechaRequerida        DateTime?         @map("fecha_requerida") @db.Date
  cantidadRequerida     Decimal           @map("cantidad_requerida") @db.Decimal(14, 4)
  // cantidadAprobada: llenada por quien autoriza el requerimiento
  cantidadAprobada      Decimal?          @map("cantidad_aprobada") @db.Decimal(14, 4)
  // cantidadAtendida: acumulado de material efectivamente provisto
  cantidadAtendida      Decimal           @default(0) @map("cantidad_atendida") @db.Decimal(14, 4)
  creadoPorUsuarioId    String            @map("creado_por_usuario_id") @db.Uuid
  atendidoPorUsuarioId  String?           @map("atendido_por_usuario_id") @db.Uuid
  observaciones         String?           @db.Text
  metadata              Json?             @db.JsonB
  creadoEn              DateTime          @default(now()) @map("creado_en")
  actualizadoEn         DateTime          @updatedAt @map("actualizado_en")

  item                 Item                  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  sede                 Sede                  @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ordenProduccion      OrdenProduccion?      @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden             Suborden?             @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  pedido               Pedido?               @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  estadoRequerimiento  EstadoSistema         @relation("RequerimientoEstado", fields: [estadoRequerimientoId], references: [id], onDelete: Restrict)
  creadoPor            Usuario               @relation("RequerimientoMaterialCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  atendidoPor          Usuario?              @relation("RequerimientoMaterialAtendidoPor", fields: [atendidoPorUsuarioId], references: [id], onDelete: SetNull)
  solicitudCompraItems SolicitudCompraItem[]
  movimientosMaterial  MovimientoMaterial[]

  @@index([itemId])
  @@index([sedeId])
  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([pedidoId])
  @@index([estadoRequerimientoId])
  @@index([tipoRequerimiento])
  @@map("requerimientos_material")
}

// ------------------------------------------------------------
// SolicitudCompra — cabecera de una solicitud de compra de materiales
// Puede originarse desde uno o varios requerimientos de material.
// estadoSolicitudId: FK a estados_sistema (módulo 'solicitud_compra').
//   Estados sugeridos: BORRADOR, PENDIENTE_AUTORIZACION, AUTORIZADA, RECHAZADA, EN_PROCESO, COMPLETADA, CANCELADA.
// proveedorId: nullable en creación; se define antes de pasar a AUTORIZADA.
// IMPORTANTE: cambios de estado deben escribirse junto con auditoria_general en transacción.
// ------------------------------------------------------------
model SolicitudCompra {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo                 String    @unique @db.VarChar(50)
  sedeId                 String    @map("sede_id") @db.Uuid
  proveedorId            String?   @map("proveedor_id") @db.Uuid
  estadoSolicitudId      String    @map("estado_solicitud_id") @db.Uuid
  creadoPorUsuarioId     String    @map("creado_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?   @map("autorizado_por_usuario_id") @db.Uuid
  fechaSolicitud         DateTime  @map("fecha_solicitud") @db.Date
  fechaRequerida         DateTime? @map("fecha_requerida") @db.Date
  observaciones          String?   @db.Text
  metadata               Json?     @db.JsonB
  creadoEn               DateTime  @default(now()) @map("creado_en")
  actualizadoEn          DateTime  @updatedAt @map("actualizado_en")

  sede            Sede                  @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  proveedor       Proveedor?            @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  estadoSolicitud EstadoSistema         @relation("SolicitudCompraEstado", fields: [estadoSolicitudId], references: [id], onDelete: Restrict)
  creadoPor       Usuario               @relation("SolicitudCompraCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor   Usuario?              @relation("SolicitudCompraAutorizadaPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)
  items           SolicitudCompraItem[]
  comprasMaterial CompraMaterial[]

  @@index([sedeId])
  @@index([proveedorId])
  @@index([estadoSolicitudId])
  @@index([fechaSolicitud])
  @@map("solicitudes_compra")
}

// ------------------------------------------------------------
// SolicitudCompraItem — línea de ítem dentro de una solicitud de compra
// requerimientoMaterialId: trazabilidad opcional hacia el requerimiento que originó esta línea.
// precioEstimado: referencia para el proceso de autorización; puede diferir del precio final.
// ------------------------------------------------------------
model SolicitudCompraItem {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  solicitudCompraId       String   @map("solicitud_compra_id") @db.Uuid
  itemId                  String   @map("item_id") @db.Uuid
  requerimientoMaterialId String?  @map("requerimiento_material_id") @db.Uuid
  cantidadSolicitada      Decimal  @map("cantidad_solicitada") @db.Decimal(14, 4)
  precioEstimado          Decimal? @map("precio_estimado") @db.Decimal(14, 4)
  observaciones           String?  @db.Text
  creadoEn                DateTime @default(now()) @map("creado_en")
  actualizadoEn           DateTime @updatedAt @map("actualizado_en")

  solicitudCompra       SolicitudCompra        @relation(fields: [solicitudCompraId], references: [id], onDelete: Cascade)
  item                  Item                   @relation(fields: [itemId], references: [id], onDelete: Restrict)
  requerimientoMaterial RequerimientoMaterial? @relation(fields: [requerimientoMaterialId], references: [id], onDelete: SetNull)
  compraItems           CompraItemMaterial[]

  @@index([solicitudCompraId])
  @@index([itemId])
  @@index([requerimientoMaterialId])
  @@map("solicitud_compra_items")
}

// ------------------------------------------------------------
// CompraMaterial — orden de compra formal emitida a un proveedor
// Puede nacer de una solicitud de compra o crearse directamente.
// estadoCompraId: FK a estados_sistema (módulo 'compra_material').
//   Estados sugeridos: BORRADOR, EMITIDA, CONFIRMADA, EN_TRANSITO, RECIBIDA_PARCIAL, RECIBIDA, CANCELADA.
// numeroOrdenCompra: número de orden generado internamente o asignado por el proveedor.
// valorTotal: denormalizado para consultas rápidas; se calcula desde los ítems.
// IMPORTANTE: cambios de estado deben escribirse junto con auditoria_general en transacción.
// ------------------------------------------------------------
model CompraMaterial {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  solicitudCompraId      String?   @map("solicitud_compra_id") @db.Uuid
  sedeId                 String    @map("sede_id") @db.Uuid
  proveedorId            String    @map("proveedor_id") @db.Uuid
  estadoCompraId         String    @map("estado_compra_id") @db.Uuid
  numeroOrdenCompra      String?   @unique @map("numero_orden_compra") @db.VarChar(80)
  creadoPorUsuarioId     String    @map("creado_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?   @map("autorizado_por_usuario_id") @db.Uuid
  fechaCompra            DateTime  @map("fecha_compra") @db.Date
  fechaEntregaEstimada   DateTime? @map("fecha_entrega_estimada") @db.Date
  // valorTotal: campo denormalizado; mantener sincronizado con suma de subtotales de ítems
  valorTotal             Decimal?  @map("valor_total") @db.Decimal(16, 4)
  observaciones          String?   @db.Text
  metadata               Json?     @db.JsonB
  creadoEn               DateTime  @default(now()) @map("creado_en")
  actualizadoEn          DateTime  @updatedAt @map("actualizado_en")

  solicitudCompra     SolicitudCompra?     @relation(fields: [solicitudCompraId], references: [id], onDelete: SetNull)
  sede                Sede                 @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  proveedor           Proveedor            @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  estadoCompra        EstadoSistema        @relation("CompraEstado", fields: [estadoCompraId], references: [id], onDelete: Restrict)
  creadoPor           Usuario              @relation("CompraMaterialCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor       Usuario?             @relation("CompraMaterialAutorizadaPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)
  items               CompraItemMaterial[]
  recepciones         RecepcionMaterial[]
  movimientosMaterial MovimientoMaterial[]

  @@index([solicitudCompraId])
  @@index([sedeId])
  @@index([proveedorId])
  @@index([estadoCompraId])
  @@index([fechaCompra])
  @@map("compras_material")
}

// ------------------------------------------------------------
// CompraItemMaterial — línea de ítem dentro de una orden de compra
// solicitudItemId: trazabilidad hacia el ítem de la solicitud de compra que lo originó.
// cantidadRecibida: se acumula a medida que llegan recepciones; nullable hasta primer ingreso.
// subtotal: precioUnitario × cantidadSolicitada; puede ajustarse al confirmar el precio real.
// ------------------------------------------------------------
model CompraItemMaterial {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  compraMaterialId   String   @map("compra_material_id") @db.Uuid
  itemId             String   @map("item_id") @db.Uuid
  solicitudItemId    String?  @map("solicitud_item_id") @db.Uuid
  cantidadSolicitada Decimal  @map("cantidad_solicitada") @db.Decimal(14, 4)
  // cantidadRecibida: acumulado de recepciones; se actualiza por transacción al recibir
  cantidadRecibida   Decimal? @map("cantidad_recibida") @db.Decimal(14, 4)
  precioUnitario     Decimal? @map("precio_unitario") @db.Decimal(14, 4)
  subtotal           Decimal? @db.Decimal(16, 4)
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  compraMaterial CompraMaterial          @relation(fields: [compraMaterialId], references: [id], onDelete: Cascade)
  item           Item                    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  solicitudItem  SolicitudCompraItem?    @relation(fields: [solicitudItemId], references: [id], onDelete: SetNull)
  recepcionItems RecepcionItemMaterial[]

  @@index([compraMaterialId])
  @@index([itemId])
  @@index([solicitudItemId])
  @@map("compra_material_items")
}

// ------------------------------------------------------------
// RecepcionMaterial — evento de recepción física de materiales en una sede
// Puede corresponder a una compra o a un traslado de otra sede.
// Al menos uno de (compraMaterialId, trasladoMaterialId) debe estar presente;
// validar en el service layer (Prisma no puede expresar CHECK con OR de nullables).
// estadoRecepcionId: FK a estados_sistema (módulo 'recepcion_material').
//   Estados sugeridos: PENDIENTE, EN_REVISION, ACEPTADA, ACEPTADA_PARCIAL, RECHAZADA.
// IMPORTANTE: al aceptar la recepción, generar movimientos_material en la misma transacción.
// ------------------------------------------------------------
model RecepcionMaterial {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  compraMaterialId     String?  @map("compra_material_id") @db.Uuid
  trasladoMaterialId   String?  @map("traslado_material_id") @db.Uuid
  sedeId               String   @map("sede_id") @db.Uuid
  estadoRecepcionId    String   @map("estado_recepcion_id") @db.Uuid
  recibidoPorUsuarioId String   @map("recibido_por_usuario_id") @db.Uuid
  fechaRecepcion       DateTime @map("fecha_recepcion")
  observaciones        String?  @db.Text
  metadata             Json?    @db.JsonB
  creadoEn             DateTime @default(now()) @map("creado_en")
  actualizadoEn        DateTime @updatedAt @map("actualizado_en")

  compraMaterial      CompraMaterial?         @relation(fields: [compraMaterialId], references: [id], onDelete: Restrict)
  trasladoMaterial    TrasladoMaterial?       @relation(fields: [trasladoMaterialId], references: [id], onDelete: Restrict)
  sede                Sede                    @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  estadoRecepcion     EstadoSistema           @relation("RecepcionEstado", fields: [estadoRecepcionId], references: [id], onDelete: Restrict)
  recibidoPor         Usuario                 @relation(fields: [recibidoPorUsuarioId], references: [id], onDelete: Restrict)
  items               RecepcionItemMaterial[]
  movimientosMaterial MovimientoMaterial[]

  @@index([compraMaterialId])
  @@index([trasladoMaterialId])
  @@index([sedeId])
  @@index([estadoRecepcionId])
  @@index([fechaRecepcion])
  @@map("recepciones_material")
}

// ------------------------------------------------------------
// RecepcionItemMaterial — detalle de cada ítem recibido en una recepción
// compraItemId: trazabilidad hacia el ítem de la compra que se está recibiendo.
// trasladoItemId: trazabilidad hacia el ítem del traslado que se está recibiendo.
// ubicacionId: ubicación física donde se almacena el material recibido en la sede.
// No tiene actualizadoEn: el registro de recepción es inmutable una vez creado.
// ------------------------------------------------------------
model RecepcionItemMaterial {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recepcionMaterialId String   @map("recepcion_material_id") @db.Uuid
  compraItemId        String?  @map("compra_item_id") @db.Uuid
  trasladoItemId      String?  @map("traslado_item_id") @db.Uuid
  itemId              String   @map("item_id") @db.Uuid
  cantidadRecibida    Decimal  @map("cantidad_recibida") @db.Decimal(14, 4)
  ubicacionId         String?  @map("ubicacion_id") @db.Uuid
  observaciones       String?  @db.Text
  creadoEn            DateTime @default(now()) @map("creado_en")

  recepcionMaterial RecepcionMaterial     @relation(fields: [recepcionMaterialId], references: [id], onDelete: Cascade)
  compraItem        CompraItemMaterial?   @relation(fields: [compraItemId], references: [id], onDelete: SetNull)
  trasladoItem      TrasladoItemMaterial? @relation(fields: [trasladoItemId], references: [id], onDelete: SetNull)
  item              Item                  @relation(fields: [itemId], references: [id], onDelete: Restrict)
  ubicacion         Ubicacion?            @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)

  @@index([recepcionMaterialId])
  @@index([itemId])
  @@index([compraItemId])
  @@index([trasladoItemId])
  @@map("recepcion_material_items")
}

// ------------------------------------------------------------
// TrasladoMaterial — movimiento de materiales entre sedes o ubicaciones
// estadoTrasladoId: FK a estados_sistema (módulo 'traslado_material').
//   Estados sugeridos: BORRADOR, PENDIENTE_AUTORIZACION, AUTORIZADO, EN_TRANSITO, RECIBIDO, CANCELADO.
// fechaEnvio: se llena cuando el traslado pasa a EN_TRANSITO.
// fechaRecepcion: se llena cuando se crea la RecepcionMaterial asociada.
// IMPORTANTE: al pasar a EN_TRANSITO, generar movimiento SALIDA_TRASLADO en sedeOrigen
//   y llenar cantidadEnviada en traslado_material_items. Todo en la misma transacción.
// ------------------------------------------------------------
model TrasladoMaterial {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo                 String    @unique @db.VarChar(50)
  sedeOrigenId           String    @map("sede_origen_id") @db.Uuid
  sedeDestinoId          String    @map("sede_destino_id") @db.Uuid
  estadoTrasladoId       String    @map("estado_traslado_id") @db.Uuid
  solicitadoPorUsuarioId String    @map("solicitado_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?   @map("autorizado_por_usuario_id") @db.Uuid
  fechaSolicitud         DateTime  @map("fecha_solicitud") @db.Date
  // fechaEnvio: obligatorio al pasar a EN_TRANSITO; validar en service layer
  fechaEnvio             DateTime? @map("fecha_envio")
  // fechaRecepcion: se llena automáticamente al crear la RecepcionMaterial
  fechaRecepcion         DateTime? @map("fecha_recepcion")
  observaciones          String?   @db.Text
  metadata               Json?     @db.JsonB
  creadoEn               DateTime  @default(now()) @map("creado_en")
  actualizadoEn          DateTime  @updatedAt @map("actualizado_en")

  sedeOrigen          Sede                   @relation("TrasladoSedeOrigen", fields: [sedeOrigenId], references: [id], onDelete: Restrict)
  sedeDestino         Sede                   @relation("TrasladoSedeDestino", fields: [sedeDestinoId], references: [id], onDelete: Restrict)
  estadoTraslado      EstadoSistema          @relation("TrasladoEstado", fields: [estadoTrasladoId], references: [id], onDelete: Restrict)
  solicitadoPor       Usuario                @relation("TrasladoMaterialSolicitadoPor", fields: [solicitadoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor       Usuario?               @relation("TrasladoMaterialAutorizadoPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)
  items               TrasladoItemMaterial[]
  recepciones         RecepcionMaterial[]
  movimientosMaterial MovimientoMaterial[]

  @@index([sedeOrigenId])
  @@index([sedeDestinoId])
  @@index([estadoTrasladoId])
  @@index([fechaSolicitud])
  @@map("traslados_material")
}

// ------------------------------------------------------------
// TrasladoItemMaterial — línea de ítem dentro de un traslado de material
// cantidadEnviada: REGLA — solo se registra cuando el traslado pasa a EN_TRANSITO.
//   Antes de ese estado, este campo debe permanecer NULL. Enforcar en service layer.
// cantidadRecibida: REGLA — solo se registra cuando existe una RecepcionMaterial asociada.
//   Al registrar la recepción, llenar este campo en la misma transacción.
// ubicacionOrigenId: ubicación física en la sede origen desde donde sale el material.
// ------------------------------------------------------------
model TrasladoItemMaterial {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trasladoMaterialId String   @map("traslado_material_id") @db.Uuid
  itemId             String   @map("item_id") @db.Uuid
  cantidadSolicitada Decimal  @map("cantidad_solicitada") @db.Decimal(14, 4)
  // cantidadEnviada: se llena SOLO al pasar traslado a EN_TRANSITO (regla de negocio crítica)
  cantidadEnviada    Decimal? @map("cantidad_enviada") @db.Decimal(14, 4)
  // cantidadRecibida: se llena SOLO cuando existe RecepcionMaterial asociada (regla de negocio crítica)
  cantidadRecibida   Decimal? @map("cantidad_recibida") @db.Decimal(14, 4)
  ubicacionOrigenId  String?  @map("ubicacion_origen_id") @db.Uuid
  observaciones      String?  @db.Text
  creadoEn           DateTime @default(now()) @map("creado_en")
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")

  trasladoMaterial TrasladoMaterial        @relation(fields: [trasladoMaterialId], references: [id], onDelete: Cascade)
  item             Item                    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  ubicacionOrigen  Ubicacion?              @relation(fields: [ubicacionOrigenId], references: [id], onDelete: SetNull)
  recepcionItems   RecepcionItemMaterial[]

  @@index([trasladoMaterialId])
  @@index([itemId])
  @@map("traslado_material_items")
}

// ------------------------------------------------------------
// MovimientoMaterial — ledger inmutable de todos los movimientos de inventario operativo
// Cada entrada representa un delta de inventario para un ítem en una sede/ubicación.
// cantidad: siempre positiva; la dirección se determina por tipoMovimiento.
// saldoResultante: snapshot de cantidadDisponible DESPUÉS de aplicar este movimiento.
//   Es inmutable y sirve para auditar el historial punto a punto.
// Fuentes opcionales (al menos una debe estar presente para trazabilidad, validar en backend):
//   trasladoMaterialId, compraMaterialId, recepcionMaterialId,
//   requerimientoMaterialId, ordenProduccionId, subordenId, pedidoId.
// creadoPorUsuarioId: nullable cuando el movimiento es generado automáticamente por el sistema.
// IMPORTANTE: toda escritura en movimientos_material debe actualizarse junto con
//   inventario_operativo en la misma transacción. No actualizar inventario_operativo por fuera
//   de este flujo, salvo ajuste autorizado con auditoria_general.
// No tiene actualizadoEn: el registro es inmutable una vez creado (ledger contable).
// ------------------------------------------------------------
model MovimientoMaterial {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId                  String                 @map("item_id") @db.Uuid
  sedeId                  String                 @map("sede_id") @db.Uuid
  ubicacionId             String?                @map("ubicacion_id") @db.Uuid
  tipoMovimiento          TipoMovimientoMaterial @map("tipo_movimiento")
  cantidad                Decimal                @db.Decimal(14, 4)
  // saldoResultante: snapshot inmutable de cantidadDisponible tras este movimiento
  saldoResultante         Decimal                @map("saldo_resultante") @db.Decimal(14, 4)
  // Referencias opcionales para trazabilidad del origen del movimiento
  trasladoMaterialId      String?                @map("traslado_material_id") @db.Uuid
  compraMaterialId        String?                @map("compra_material_id") @db.Uuid
  recepcionMaterialId     String?                @map("recepcion_material_id") @db.Uuid
  requerimientoMaterialId String?                @map("requerimiento_material_id") @db.Uuid
  ordenProduccionId       String?                @map("orden_produccion_id") @db.Uuid
  subordenId              String?                @map("suborden_id") @db.Uuid
  pedidoId                String?                @map("pedido_id") @db.Uuid
  creadoPorUsuarioId      String?                @map("creado_por_usuario_id") @db.Uuid
  descripcion             String?                @db.Text
  metadata                Json?                  @db.JsonB
  creadoEn                DateTime               @default(now()) @map("creado_en")

  item                  Item                   @relation(fields: [itemId], references: [id], onDelete: Restrict)
  sede                  Sede                   @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ubicacion             Ubicacion?             @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)
  trasladoMaterial      TrasladoMaterial?      @relation(fields: [trasladoMaterialId], references: [id], onDelete: SetNull)
  compraMaterial        CompraMaterial?        @relation(fields: [compraMaterialId], references: [id], onDelete: SetNull)
  recepcionMaterial     RecepcionMaterial?     @relation(fields: [recepcionMaterialId], references: [id], onDelete: SetNull)
  requerimientoMaterial RequerimientoMaterial? @relation(fields: [requerimientoMaterialId], references: [id], onDelete: SetNull)
  ordenProduccion       OrdenProduccion?       @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden              Suborden?              @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  pedido                Pedido?                @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  creadoPor             Usuario?               @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([sedeId])
  @@index([tipoMovimiento])
  @@index([creadoEn])
  @@index([trasladoMaterialId])
  @@index([compraMaterialId])
  @@index([recepcionMaterialId])
  @@index([ordenProduccionId])
  @@map("movimientos_material")
}

// ------------------------------------------------------------
// MaterialReservado — reservas de material para órdenes, subórdenes o pedidos
// Una reserva incrementa cantidadReservada en inventario_operativo sin mover cantidadDisponible.
// Al consumir: estadoReserva → CONSUMIDA y se emite MovimientoMaterial SALIDA_PRODUCCION.
// Al liberar: estadoReserva → LIBERADA y se emite MovimientoMaterial LIBERACION_RESERVA.
// IMPORTANTE: cambios de estado deben actualizarse junto con inventario_operativo
//   y auditoria_general dentro de la misma transacción.
// ------------------------------------------------------------
model MaterialReservado {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId             String                @map("item_id") @db.Uuid
  sedeId             String                @map("sede_id") @db.Uuid
  ubicacionId        String?               @map("ubicacion_id") @db.Uuid
  pedidoId           String?               @map("pedido_id") @db.Uuid
  ordenProduccionId  String?               @map("orden_produccion_id") @db.Uuid
  subordenId         String?               @map("suborden_id") @db.Uuid
  cantidadReservada  Decimal               @map("cantidad_reservada") @db.Decimal(14, 4)
  estadoReserva      EstadoReservaMaterial @default(ACTIVA) @map("estado_reserva")
  creadoPorUsuarioId String                @map("creado_por_usuario_id") @db.Uuid
  fechaReserva       DateTime              @map("fecha_reserva")
  observaciones      String?               @db.Text
  metadata           Json?                 @db.JsonB
  creadoEn           DateTime              @default(now()) @map("creado_en")
  actualizadoEn      DateTime              @updatedAt @map("actualizado_en")

  item            Item             @relation(fields: [itemId], references: [id], onDelete: Restrict)
  sede            Sede             @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ubicacion       Ubicacion?       @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)
  pedido          Pedido?          @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  ordenProduccion OrdenProduccion? @relation(fields: [ordenProduccionId], references: [id], onDelete: SetNull)
  suborden        Suborden?        @relation(fields: [subordenId], references: [id], onDelete: SetNull)
  creadoPor       Usuario          @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([itemId])
  @@index([sedeId])
  @@index([pedidoId])
  @@index([ordenProduccionId])
  @@index([subordenId])
  @@index([estadoReserva])
  @@map("material_reservado")
}

// ------------------------------------------------------------
// AbastecimientoAlerta — alertas operativas del módulo de abastecimiento
// Complementa abastecimiento; no reemplaza alertas_sistema del Bloque 8.
// creadoPorUsuarioId: nullable cuando la alerta es generada automáticamente por el sistema.
// motivoCierre: CAMPO REQUERIDO FUNCIONALMENTE al cerrar; nullable en BD para generaciones
//   automáticas sin usuario. Validar en service layer que se llene al cerrar.
// abierta: false cuando la alerta fue revisada y resuelta (no se elimina físicamente).
// IMPORTANTE: el cierre debe escribirse junto con auditoria_general en la misma transacción.
// ------------------------------------------------------------
model AbastecimientoAlerta {
  id                  String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipoAlerta          TipoAlertaAbastecimiento @map("tipo_alerta")
  itemId              String?                  @map("item_id") @db.Uuid
  sedeId              String?                  @map("sede_id") @db.Uuid
  descripcion         String                   @db.Text
  abierta             Boolean                  @default(true)
  // motivoCierre: debe llenarse al cerrar la alerta; nullable para compatibilidad con sistema
  motivoCierre        String?                  @map("motivo_cierre") @db.Text
  creadoPorUsuarioId  String?                  @map("creado_por_usuario_id") @db.Uuid
  cerradaPorUsuarioId String?                  @map("cerrada_por_usuario_id") @db.Uuid
  fechaCierre         DateTime?                @map("fecha_cierre")
  metadata            Json?                    @db.JsonB
  creadoEn            DateTime                 @default(now()) @map("creado_en")
  actualizadoEn       DateTime                 @updatedAt @map("actualizado_en")

  item       Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  sede       Sede?    @relation(fields: [sedeId], references: [id], onDelete: SetNull)
  creadoPor  Usuario? @relation("AbastecimientoAlertaCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)
  cerradaPor Usuario? @relation("AbastecimientoAlertaCerradaPor", fields: [cerradaPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([tipoAlerta])
  @@index([itemId])
  @@index([sedeId])
  @@index([abierta])
  @@map("abastecimiento_alertas")
}

// ------------------------------------------------------------
// InventarioOperativo — saldo operativo running por ítem, sede y ubicación
// NO reemplaza ContaPyme. Es un saldo operativo interno para control de producción.
// Solo debe actualizarse desde movimientos_material mediante transacción atómica.
// Excepción: ajuste autorizado con auditoria_general en la misma transacción.
//
// cantidadDisponible: stock físico disponible para asignar (no reservado, no en producción).
// cantidadReservada: material asignado a órdenes/pedidos pero aún no consumido.
// cantidadEnProduccion: material que ya salió de almacén y está siendo procesado en producción.
// cantidadEnTransito: material enviado desde otra sede pero aún no recibido.
//
// CONSTRAINT TÉCNICO (aplicar manualmente en migración PG18):
//   La unicidad de (itemId, sedeId, ubicacionId) con ubicacionId nullable requiere
//   un índice NULLS NOT DISTINCT. Prisma genera la constraint estándar que NO la enforza
//   cuando ubicacionId es NULL (comportamiento de PostgreSQL pre-15 para NULL en UNIQUE).
//   Reemplazar con:
//     DROP INDEX inventario_operativo_item_id_sede_id_ubicacion_id_key;
//     CREATE UNIQUE INDEX inventario_operativo_item_id_sede_id_ubicacion_id_key
//     ON inventario_operativo (item_id, sede_id, ubicacion_id) NULLS NOT DISTINCT;
// ------------------------------------------------------------
model InventarioOperativo {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId               String   @map("item_id") @db.Uuid
  sedeId               String   @map("sede_id") @db.Uuid
  ubicacionId          String?  @map("ubicacion_id") @db.Uuid
  cantidadDisponible   Decimal  @default(0) @map("cantidad_disponible") @db.Decimal(14, 4)
  cantidadReservada    Decimal  @default(0) @map("cantidad_reservada") @db.Decimal(14, 4)
  cantidadEnProduccion Decimal  @default(0) @map("cantidad_en_produccion") @db.Decimal(14, 4)
  cantidadEnTransito   Decimal  @default(0) @map("cantidad_en_transito") @db.Decimal(14, 4)
  // ultimaActualizacion: se llena explícitamente en el servicio al aplicar cada movimiento
  ultimaActualizacion  DateTime @map("ultima_actualizacion")
  metadata             Json?    @db.JsonB
  creadoEn             DateTime @default(now()) @map("creado_en")

  item      Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  sede      Sede       @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ubicacion Ubicacion? @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)

  // Ver nota técnica en comentario del modelo sobre NULLS NOT DISTINCT
  @@unique([itemId, sedeId, ubicacionId])
  @@index([itemId])
  @@index([sedeId])
  @@map("inventario_operativo")
}

// =============================================================
// BLOQUE 7 — Despacho, Checklist, Ubicación y Evidencias
// =============================================================

// ------------------------------------------------------------
// Enum: tipo de evidencia adjunta a un despacho
// Tipo operativo cerrado; no requiere configuración dinámica.
// FOTO / VIDEO: evidencia visual del estado del producto al despachar.
// DOCUMENTO: soporte escrito (remisión, autorización, guía de transporte).
// FIRMA: firma digital o foto de firma del receptor.
// OBSERVACION: nota operativa sin archivo adjunto.
// ------------------------------------------------------------
enum TipoEvidenciaDespacho {
  FOTO
  VIDEO
  DOCUMENTO
  FIRMA
  OBSERVACION
}

// ------------------------------------------------------------
// TipoValidacionDespacho — catálogo configurable de tipos de validación para checklist
// Tabla configurable: gerencia puede agregar, activar o desactivar validaciones sin migración.
// ordenVisual: define el orden de presentación en la interfaz del checklist.
// metadata: permite adjuntar parámetros de configuración adicionales por tipo.
// Ejemplos: VERIFICACION_CANTIDAD, REVISION_EMBALAJE, CONFIRMACION_CLIENTE, REVISION_DOCUMENTOS.
// ------------------------------------------------------------
model TipoValidacionDespacho {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo        String   @unique @db.VarChar(50)
  nombre        String   @db.VarChar(150)
  descripcion   String?  @db.Text
  activo        Boolean  @default(true)
  ordenVisual   Int      @map("orden_visual")
  metadata      Json?    @db.JsonB
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  checklistItems ChecklistDespachoItem[]

  @@index([activo])
  @@index([ordenVisual])
  @@map("tipos_validacion_despacho")
}

// ------------------------------------------------------------
// Despacho — evento formal de salida de un pedido desde la sede
// estadoDespachoId: FK a estados_sistema (módulo 'despacho').
//   Estados sugeridos: PENDIENTE, AUTORIZADO, EN_CARGUE, DESPACHADO, ENTREGADO, RECHAZADO, CANCELADO.
// autorizadoPorUsuarioId: nullable; el despacho puede no requerir autorización explícita.
// despachoPorUsuarioId: usuario que ejecuta físicamente el despacho (operario de bodega).
// creadoPorUsuarioId: usuario que registra el evento en el sistema.
// fechaDespacho: momento real en que el pedido sale de la sede.
// IMPORTANTE: fechaListoDespacho y fechaDespachoCompleto viven desnormalizados en Pedido;
//   se actualizan desde el service layer al cambiar estado del despacho.
// IMPORTANTE: cambios de estado deben escribirse junto con auditoria_general en transacción.
// ------------------------------------------------------------
model Despacho {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId               String   @map("pedido_id") @db.Uuid
  sedeId                 String   @map("sede_id") @db.Uuid
  estadoDespachoId       String   @map("estado_despacho_id") @db.Uuid
  creadoPorUsuarioId     String   @map("creado_por_usuario_id") @db.Uuid
  despachoPorUsuarioId   String   @map("despacho_por_usuario_id") @db.Uuid
  autorizadoPorUsuarioId String?  @map("autorizado_por_usuario_id") @db.Uuid
  fechaDespacho          DateTime @map("fecha_despacho")
  observaciones          String?  @db.Text
  metadata               Json?    @db.JsonB
  creadoEn               DateTime @default(now()) @map("creado_en")
  actualizadoEn          DateTime @updatedAt @map("actualizado_en")

  pedido         Pedido                 @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sede           Sede                   @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  estadoDespacho EstadoSistema          @relation("DespachoEstado", fields: [estadoDespachoId], references: [id], onDelete: Restrict)
  creadoPor      Usuario                @relation("DespachoCreadoPor", fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)
  despachoPor    Usuario                @relation("DespachoEncargadoPor", fields: [despachoPorUsuarioId], references: [id], onDelete: Restrict)
  autorizadoPor  Usuario?               @relation("DespachoAutorizadoPor", fields: [autorizadoPorUsuarioId], references: [id], onDelete: SetNull)
  items          DespachoItem[]
  autorizaciones DespachoAutorizacion[]
  checklists     ChecklistDespacho[]
  evidencias     EvidenciaDespacho[]

  @@index([pedidoId])
  @@index([sedeId])
  @@index([estadoDespachoId])
  @@index([fechaDespacho])
  @@map("despachos")
}

// ------------------------------------------------------------
// DespachoItem — detalle de ítems despachados en un evento de despacho
// cantidadPendientePosterior: CAMPO CALCULADO INMUTABLE — snapshot de la cantidad que quedó
//   pendiente DESPUÉS de este despacho.
//   Fórmula: cantidadPendiente_antes_del_despacho − cantidadDespachada
//   Se calcula en el service layer antes de insertar; nunca se modifica retroactivamente.
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model DespachoItem {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  despachoId                 String   @map("despacho_id") @db.Uuid
  pedidoItemId               String   @map("pedido_item_id") @db.Uuid
  cantidadDespachada         Decimal  @map("cantidad_despachada") @db.Decimal(14, 4)
  // CAMPO CALCULADO INMUTABLE: snapshot de cantidad pendiente después de este despacho
  cantidadPendientePosterior Decimal  @map("cantidad_pendiente_posterior") @db.Decimal(14, 4)
  observaciones              String?  @db.Text
  creadoEn                   DateTime @default(now()) @map("creado_en")

  despacho   Despacho   @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  pedidoItem PedidoItem @relation(fields: [pedidoItemId], references: [id], onDelete: Restrict)

  @@index([despachoId])
  @@index([pedidoItemId])
  @@map("despacho_items")
}

// ------------------------------------------------------------
// DespachoAutorizacion — registro de decisión de autorización sobre un despacho
// aprobada: true si autorizó, false si rechazó.
// motivoRechazo: obligatorio en service layer cuando aprobada = false.
// No tiene actualizadoEn: el registro de autorización es inmutable una vez creado.
// IMPORTANTE: la creación de una autorización debe escribirse junto con auditoria_general
//   en la misma transacción; el cambio de estado en Despacho también.
// ------------------------------------------------------------
model DespachoAutorizacion {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  despachoId             String   @map("despacho_id") @db.Uuid
  autorizadoPorUsuarioId String   @map("autorizado_por_usuario_id") @db.Uuid
  aprobada               Boolean
  // motivoRechazo: obligatorio cuando aprobada = false; validar en service layer
  motivoRechazo          String?  @map("motivo_rechazo") @db.Text
  observaciones          String?  @db.Text
  creadoEn               DateTime @default(now()) @map("creado_en")

  despacho      Despacho @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  autorizadoPor Usuario  @relation(fields: [autorizadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([despachoId])
  @@index([autorizadoPorUsuarioId])
  @@map("despacho_autorizaciones")
}

// ------------------------------------------------------------
// ChecklistDespacho — cabecera de un checklist de validación para un despacho
// Un despacho puede tener más de un checklist (ej: pre-cargue y post-cargue).
// completado: true cuando todos los ítems del checklist han sido marcados.
// completadoPorUsuarioId: usuario que marcó el checklist como completo.
// ------------------------------------------------------------
model ChecklistDespacho {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  despachoId             String    @map("despacho_id") @db.Uuid
  completado             Boolean   @default(false)
  completadoPorUsuarioId String?   @map("completado_por_usuario_id") @db.Uuid
  fechaCompletado        DateTime? @map("fecha_completado")
  observaciones          String?   @db.Text
  creadoEn               DateTime  @default(now()) @map("creado_en")
  actualizadoEn          DateTime  @updatedAt @map("actualizado_en")

  despacho      Despacho                @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  completadoPor Usuario?                @relation(fields: [completadoPorUsuarioId], references: [id], onDelete: SetNull)
  items         ChecklistDespachoItem[]

  @@index([despachoId])
  @@map("checklist_despacho")
}

// ------------------------------------------------------------
// ChecklistDespachoItem — ítem individual verificado dentro de un checklist de despacho
// tipoValidacionDespachoId: FK obligatorio a tipos_validacion_despacho (no texto libre).
// aprobado: resultado de la verificación (true = cumple, false = no cumple).
// IMPORTANTE: si algún ítem queda en false, la regla de negocio determina si el despacho
//   puede continuar o queda bloqueado (validar en service layer según tipo de validación).
// ------------------------------------------------------------
model ChecklistDespachoItem {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checklistDespachoId      String   @map("checklist_despacho_id") @db.Uuid
  tipoValidacionDespachoId String   @map("tipo_validacion_despacho_id") @db.Uuid
  aprobado                 Boolean
  observaciones            String?  @db.Text
  creadoEn                 DateTime @default(now()) @map("creado_en")
  actualizadoEn            DateTime @updatedAt @map("actualizado_en")

  checklistDespacho      ChecklistDespacho      @relation(fields: [checklistDespachoId], references: [id], onDelete: Cascade)
  tipoValidacionDespacho TipoValidacionDespacho @relation(fields: [tipoValidacionDespachoId], references: [id], onDelete: Restrict)

  @@index([checklistDespachoId])
  @@index([tipoValidacionDespachoId])
  @@map("checklist_despacho_items")
}

// ------------------------------------------------------------
// UbicacionPedido — ubicación física actual de un pedido dentro de la operación
// Representa el estado actual de dónde se encuentra el pedido en la sede.
// pedidoId es @unique: solo existe UN registro de ubicación actual por pedido.
// REGLA CRÍTICA: toda modificación de UbicacionPedido debe insertarse simultáneamente
//   en HistorialUbicacionPedido dentro de la misma transacción (atomicidad garantizada).
//   Así se mantiene coherencia entre el estado actual y el historial completo.
// ultimaActualizacion: se llena explícitamente en el service al modificar la ubicación.
// ------------------------------------------------------------
model UbicacionPedido {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId                String   @unique @map("pedido_id") @db.Uuid
  sedeId                  String   @map("sede_id") @db.Uuid
  ubicacionId             String?  @map("ubicacion_id") @db.Uuid
  descripcion             String?  @db.Text
  actualizadoPorUsuarioId String   @map("actualizado_por_usuario_id") @db.Uuid
  // ultimaActualizacion: se llena explícitamente al modificar; no usar @updatedAt
  ultimaActualizacion     DateTime @map("ultima_actualizacion")
  creadoEn                DateTime @default(now()) @map("creado_en")

  pedido         Pedido     @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sede           Sede       @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ubicacion      Ubicacion? @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)
  actualizadoPor Usuario    @relation(fields: [actualizadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([sedeId])
  @@index([ubicacionId])
  @@map("ubicacion_pedido")
}

// ------------------------------------------------------------
// HistorialUbicacionPedido — registro inmutable de cada cambio de ubicación de un pedido
// REGLA CRÍTICA: debe insertarse en la misma transacción que actualiza UbicacionPedido.
//   Garantiza que el historial siempre refleja todos los movimientos sin brechas.
// No tiene actualizadoEn: el registro es inmutable una vez creado.
// ------------------------------------------------------------
model HistorialUbicacionPedido {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedidoId               String   @map("pedido_id") @db.Uuid
  sedeId                 String   @map("sede_id") @db.Uuid
  ubicacionId            String?  @map("ubicacion_id") @db.Uuid
  descripcion            String?  @db.Text
  registradoPorUsuarioId String   @map("registrado_por_usuario_id") @db.Uuid
  creadoEn               DateTime @default(now()) @map("creado_en")

  pedido        Pedido     @relation(fields: [pedidoId], references: [id], onDelete: Restrict)
  sede          Sede       @relation(fields: [sedeId], references: [id], onDelete: Restrict)
  ubicacion     Ubicacion? @relation(fields: [ubicacionId], references: [id], onDelete: SetNull)
  registradoPor Usuario    @relation(fields: [registradoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([sedeId])
  @@index([creadoEn])
  @@map("historial_ubicacion_pedido")
}

// ------------------------------------------------------------
// EvidenciaDespacho — archivos o notas adjuntas como evidencia de un despacho
// rutaArchivo: ruta interna del archivo físico (no URL pública directa).
// nombreOriginal: nombre del archivo como lo subió el usuario.
// Para OBSERVACION: rutaArchivo y nombreOriginal son nullable (solo texto descriptivo).
// No tiene actualizadoEn: la evidencia es inmutable una vez registrada.
// ------------------------------------------------------------
model EvidenciaDespacho {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  despachoId         String                @map("despacho_id") @db.Uuid
  tipoEvidencia      TipoEvidenciaDespacho @map("tipo_evidencia")
  rutaArchivo        String?               @map("ruta_archivo") @db.VarChar(500)
  nombreOriginal     String?               @map("nombre_original") @db.VarChar(255)
  descripcion        String?               @db.Text
  creadoPorUsuarioId String                @map("creado_por_usuario_id") @db.Uuid
  creadoEn           DateTime              @default(now()) @map("creado_en")

  despacho  Despacho @relation(fields: [despachoId], references: [id], onDelete: Cascade)
  creadoPor Usuario  @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: Restrict)

  @@index([despachoId])
  @@index([tipoEvidencia])
  @@map("evidencias_despacho")
}

// ============================================================
// BLOQUE 8 — Notificaciones, alertas, eventos y dashboards
// ============================================================

// ------------------------------------------------------------
// Canal por el que se envía una notificación o evento
// ------------------------------------------------------------
enum CanalNotificacion {
  IN_APP
  EMAIL
  SMS
  WEBHOOK
  PUSH
}

// ------------------------------------------------------------
// Estado del intento de envío de un EventoNotificacion
// ------------------------------------------------------------
enum EstadoEnvioNotificacion {
  PENDIENTE
  EN_PROCESO
  ENVIADO
  FALLIDO
  CANCELADO
}

// ------------------------------------------------------------
// Prioridad de una notificación interna o alerta
// ------------------------------------------------------------
enum PrioridadNotificacion {
  ALTA
  MEDIA
  BAJA
}

// ------------------------------------------------------------
// Tipo semántico de un mensaje de notificación interna
// ------------------------------------------------------------
enum TipoMensajeNotificacion {
  INFORMACION
  ADVERTENCIA
  ALERTA
  CRITICA
  CONFIRMACION
}

// ------------------------------------------------------------
// NotificacionUsuario — mensajes internos dirigidos a un
// usuario específico. Se generan desde lógica de negocio
// (cambios de estado, asignaciones, PQRS, etc.).
// leida y fechaLeida permiten controlar acuse de recibo.
// ------------------------------------------------------------
model NotificacionUsuario {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  destinatarioUsuarioId String                  @map("destinatario_usuario_id") @db.Uuid
  creadoPorUsuarioId    String?                 @map("creado_por_usuario_id") @db.Uuid
  /// Tipo semántico del mensaje: INFORMACION, ADVERTENCIA, ALERTA, CRITICA, CONFIRMACION
  tipoMensaje           TipoMensajeNotificacion @map("tipo_mensaje")
  prioridad             PrioridadNotificacion   @default(MEDIA)
  titulo                String                  @db.VarChar(200)
  cuerpo                String                  @db.Text
  /// Tipo de entidad relacionada (ej: "pedido", "orden", "pqrs").
  /// El backend resuelve la entidad usando un resolvedor centralizado con entidadTipo + entidadId.
  entidadTipo           String?                 @map("entidad_tipo") @db.VarChar(80)
  /// UUID de la entidad relacionada. No es FK directa para evitar rigidez.
  entidadId             String?                 @map("entidad_id") @db.Uuid
  leida                 Boolean                 @default(false)
  fechaLeida            DateTime?               @map("fecha_leida")
  creadoEn              DateTime                @default(now()) @map("creado_en")

  destinatario Usuario  @relation("NotificacionDestinoUsuario", fields: [destinatarioUsuarioId], references: [id], onDelete: Restrict)
  creadoPor    Usuario? @relation("NotificacionCreadaPor", fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([destinatarioUsuarioId])
  @@index([leida])
  @@index([tipoMensaje])
  @@index([creadoEn])
  @@map("notificaciones_usuario")
}

// ------------------------------------------------------------
// AlertaSistema — alertas operativas genéricas no limitadas
// a un único usuario. Pueden estar dirigidas a uno o más roles
// mediante AlertaRolDestino.
// entidadTipo + entidadId: resolvedor centralizado en backend.
// ------------------------------------------------------------
model AlertaSistema {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creadoPorUsuarioId String?                 @map("creado_por_usuario_id") @db.Uuid
  tipoMensaje        TipoMensajeNotificacion @map("tipo_mensaje")
  prioridad          PrioridadNotificacion   @default(MEDIA)
  titulo             String                  @db.VarChar(200)
  cuerpo             String                  @db.Text
  /// Tipo de entidad relacionada (ej: "pedido", "suborden", "compra").
  entidadTipo        String?                 @map("entidad_tipo") @db.VarChar(80)
  entidadId          String?                 @map("entidad_id") @db.Uuid
  /// Metadata adicional estructurada para contexto extra (umbrales, valores, etc.)
  metadata           Json?                   @db.JsonB
  activa             Boolean                 @default(true)
  creadoEn           DateTime                @default(now()) @map("creado_en")
  cerradaEn          DateTime?               @map("cerrada_en")

  creadoPor    Usuario?           @relation(fields: [creadoPorUsuarioId], references: [id], onDelete: SetNull)
  rolesDestino AlertaRolDestino[]

  @@index([activa])
  @@index([prioridad])
  @@index([creadoEn])
  @@map("alertas_sistema")
}

// ------------------------------------------------------------
// AlertaRolDestino — relación N:M entre AlertaSistema y Rol.
// Permite que una alerta sea visible para múltiples roles.
// La combinación alertaSistemaId + rolId debe ser única.
// ------------------------------------------------------------
model AlertaRolDestino {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertaSistemaId String   @map("alerta_sistema_id") @db.Uuid
  rolId           String   @map("rol_id") @db.Uuid
  creadoEn        DateTime @default(now()) @map("creado_en")

  alertaSistema AlertaSistema @relation(fields: [alertaSistemaId], references: [id], onDelete: Cascade)
  rol           Rol           @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([alertaSistemaId, rolId])
  @@index([rolId])
  @@map("alerta_roles_destino")
}

// ------------------------------------------------------------
// EventoNotificacion — cola desacoplada para canales futuros
// (email, SMS, webhook, push). Permite reintentos por canal
// sin acoplarse al modelo de negocio.
// destinatarioUsuarioId y rolDestinoId son ambos opcionales:
//   - usuario concreto O rol destino, o ninguno si es broadcast.
// intentos registra número de intentos de envío.
// ------------------------------------------------------------
model EventoNotificacion {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  destinatarioUsuarioId String?                 @map("destinatario_usuario_id") @db.Uuid
  rolDestinoId          String?                 @map("rol_destino_id") @db.Uuid
  canal                 CanalNotificacion
  tipoMensaje           TipoMensajeNotificacion @map("tipo_mensaje")
  prioridad             PrioridadNotificacion   @default(MEDIA)
  titulo                String                  @db.VarChar(200)
  cuerpo                String                  @db.Text
  /// Tipo de entidad relacionada. Backend resuelve con entidadTipo + entidadId.
  entidadTipo           String?                 @map("entidad_tipo") @db.VarChar(80)
  entidadId             String?                 @map("entidad_id") @db.Uuid
  /// Payload serializado para el canal (ej: template email, payload webhook)
  payload               Json?                   @db.JsonB
  estadoEnvio           EstadoEnvioNotificacion @default(PENDIENTE) @map("estado_envio")
  intentos              Int                     @default(0)
  proximoIntento        DateTime?               @map("proximo_intento")
  /// Mensaje de error del último intento fallido
  mensajeError          String?                 @map("mensaje_error") @db.Text
  creadoEn              DateTime                @default(now()) @map("creado_en")
  procesadoEn           DateTime?               @map("procesado_en")

  destinatario Usuario?                @relation(fields: [destinatarioUsuarioId], references: [id], onDelete: SetNull)
  rolDestino   Rol?                    @relation(fields: [rolDestinoId], references: [id], onDelete: SetNull)
  historial    HistorialNotificacion[]

  @@index([estadoEnvio])
  @@index([canal])
  @@index([proximoIntento])
  @@index([destinatarioUsuarioId])
  @@map("eventos_notificacion")
}

// ------------------------------------------------------------
// ConfiguracionNotificacion — define qué eventos generan
// notificaciones y por qué canal, por rol o usuario específico.
// rolDestinoId y usuarioDestinoId son nullable: permiten
// configurar para un rol completo o un usuario concreto.
// ADVERTENCIA: El índice único (tipoEvento, canal, rolDestinoId,
// usuarioDestinoId) tiene columnas nullable. Prisma genera un
// índice estándar que no garantiza unicidad cuando hay NULLs.
// Reemplazar en migración por:
//   CREATE UNIQUE INDEX ON configuracion_notificacion
//     (tipo_evento, canal, rol_destino_id, usuario_destino_id)
//     NULLS NOT DISTINCT;
// ------------------------------------------------------------
model ConfiguracionNotificacion {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Código del evento de negocio que dispara la notificación (ej: "pedido.validado", "orden.cancelada")
  tipoEvento       String            @map("tipo_evento") @db.VarChar(100)
  canal            CanalNotificacion
  rolDestinoId     String?           @map("rol_destino_id") @db.Uuid
  usuarioDestinoId String?           @map("usuario_destino_id") @db.Uuid
  activo           Boolean           @default(true)
  /// Template del título con placeholders (ej: "Pedido {{numeroPedido}} validado")
  templateTitulo   String?           @map("template_titulo") @db.VarChar(200)
  /// Template del cuerpo del mensaje con placeholders
  templateCuerpo   String?           @map("template_cuerpo") @db.Text
  creadoEn         DateTime          @default(now()) @map("creado_en")
  actualizadoEn    DateTime          @updatedAt @map("actualizado_en")

  rolDestino     Rol?     @relation(fields: [rolDestinoId], references: [id], onDelete: SetNull)
  usuarioDestino Usuario? @relation(fields: [usuarioDestinoId], references: [id], onDelete: SetNull)

  @@unique([tipoEvento, canal, rolDestinoId, usuarioDestinoId])
  @@index([tipoEvento])
  @@index([activo])
  @@map("configuracion_notificacion")
}

// ------------------------------------------------------------
// ConfiguracionDashboard — define qué widgets son visibles
// para cada rol. No almacena datos operativos, solo configuración
// de UI. El frontend consulta los widgets activos por rol
// y los renderiza con sus parámetros.
// ------------------------------------------------------------
model ConfiguracionDashboard {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolId         String   @map("rol_id") @db.Uuid
  /// Código único del widget (ej: "resumen_pedidos", "alertas_abastecimiento")
  codigoWidget  String   @map("codigo_widget") @db.VarChar(100)
  nombreWidget  String   @map("nombre_widget") @db.VarChar(150)
  visible       Boolean  @default(true)
  /// Posición en el grid del dashboard (orden de aparición)
  posicion      Int      @default(0)
  /// Configuración específica del widget (tamaño, filtros fijos, etc.)
  configuracion Json?    @db.JsonB
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  rol Rol @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([rolId, codigoWidget])
  @@index([rolId])
  @@index([visible])
  @@map("configuracion_dashboard")
}

// ------------------------------------------------------------
// ConfiguracionMetrica — define qué métricas están activas
// por rol. Las métricas V1.0 se calculan en tiempo real
// desde datos existentes (no se cachean reportes).
// configuracion JSONB estructura sugerida:
//   {
//     "filtros": ["sedeId", "fechaDesde"],
//     "agrupacion": "dia",
//     "umbralAlerta": 5
//   }
// ------------------------------------------------------------
model ConfiguracionMetrica {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rolId         String   @map("rol_id") @db.Uuid
  /// Código único de la métrica (ej: "pedidos_activos", "tiempo_promedio_corte")
  codigoMetrica String   @map("codigo_metrica") @db.VarChar(100)
  nombreMetrica String   @map("nombre_metrica") @db.VarChar(150)
  activo        Boolean  @default(true)
  /// Estructura sugerida: { "filtros": ["sedeId","fechaDesde"], "agrupacion": "dia", "umbralAlerta": 5 }
  configuracion Json?    @db.JsonB
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  rol Rol @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@unique([rolId, codigoMetrica])
  @@index([rolId])
  @@index([activo])
  @@map("configuracion_metricas")
}

// ------------------------------------------------------------
// HistorialNotificacion — registro inmutable de cada intento
// de envío de un EventoNotificacion. Sin actualizadoEn
// por ser tabla de auditoría de trazabilidad de envíos.
// ------------------------------------------------------------
model HistorialNotificacion {
  id                   String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventoNotificacionId String                  @map("evento_notificacion_id") @db.Uuid
  usuarioReceptorId    String?                 @map("usuario_receptor_id") @db.Uuid
  canal                CanalNotificacion
  estadoEnvio          EstadoEnvioNotificacion @map("estado_envio")
  intentoNumero        Int                     @map("intento_numero")
  /// Respuesta del canal externo o descripción del resultado
  respuestaCanal       String?                 @map("respuesta_canal") @db.Text
  mensajeError         String?                 @map("mensaje_error") @db.Text
  creadoEn             DateTime                @default(now()) @map("creado_en")

  eventoNotificacion EventoNotificacion @relation(fields: [eventoNotificacionId], references: [id], onDelete: Cascade)
  usuarioReceptor    Usuario?           @relation(fields: [usuarioReceptorId], references: [id], onDelete: SetNull)

  @@index([eventoNotificacionId])
  @@index([canal])
  @@index([estadoEnvio])
  @@map("historial_notificaciones")
}
